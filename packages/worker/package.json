{
  "name": "@upriver/worker",
  "version": "0.1.0",
  "description": "Inngest worker — runs upriver pipeline stages off the dashboard, syncing artifacts through the Supabase bucket",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./functions": {
      "import": "./dist/functions/index.js",
      "types": "./dist/functions/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node dist/serve.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@upriver/core": "workspace:*",
    "express": "^4.21.2",
    "inngest": "^3.27.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
