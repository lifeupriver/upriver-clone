# Upriver dashboard — environment contract
#
# Every variable the dashboard reads, with a one-line purpose. Copy to `.env`
# for local SSR, or set each one in the Vercel project (Settings → Environment
# Variables) for the hosted deploy. `scripts/dashboard-preflight.mjs` checks the
# REQUIRED block below before a deploy is considered safe.
#
# Names here are the names the CODE reads (grep `process.env[` across
# packages/dashboard/src and packages/core/src) — not aliases. In particular the
# Supabase keys are PUBLISHABLE_KEY (anon) and SERVICE_KEY (service-role), which
# is what auth.ts, share-token.ts, rate-limit.ts and the data source consume.

# ── REQUIRED for a hosted (Supabase) deploy ──────────────────────────────────

# Which backend the dashboard reads/writes. `supabase` on Vercel; `local` reads
# clients/<slug>/ from disk and shells out to the CLI (operator laptop only).
UPRIVER_DATA_SOURCE=supabase

# Supabase project REST URL, e.g. https://abcdefgh.supabase.co
UPRIVER_SUPABASE_URL=

# Publishable (anon) key. Powers operator-session auth (@supabase/ssr cookies in
# middleware/auth.ts) and the anon SELECT that validates share tokens. Safe to
# expose to the browser.
UPRIVER_SUPABASE_PUBLISHABLE_KEY=

# Service-role key — SERVER ONLY, never ship to the client. Used for: data-source
# Storage reads/writes, minting/revoking share tokens, and the rate_limit_hit
# RPC. Treat as a secret; set it as a non-public Vercel env var.
UPRIVER_SUPABASE_SERVICE_KEY=

# The chatbot's only LLM key. The dashboard runs on Vercel where the operator's
# Max-plan CLI auth is unavailable, so the coverage chatbot calls the Anthropic
# API directly with this key. Required for /api/profile/<slug> to function.
ANTHROPIC_API_KEY=

# ── OPTIONAL — sensible defaults; override only if you need to ────────────────

# Storage bucket the data source reads/writes. Defaults to `upriver` when unset
# (packages/core/src/data/supabase.ts). Set it if your bucket is named otherwise.
UPRIVER_SUPABASE_BUCKET=upriver

# Accepted by share-token.ts ONLY, as a fallback alias for SERVICE_KEY above.
# Prefer setting UPRIVER_SUPABASE_SERVICE_KEY; leave this unset unless an existing
# secret store already uses this name.
# UPRIVER_SUPABASE_SERVICE_ROLE_KEY=

# Override the coverage chatbot's model id (default lives in lib/coverage-chat.ts).
# UPRIVER_CHATBOT_MODEL=

# Record operator/audit events (share_token.mint, etc.) to the dashboard_events
# table. Any non-empty value enables it; unset disables recording.
# DASHBOARD_EVENTS_ENABLED=1

# Worker/Inngest enqueue endpoint + signing key. Unused in the current deploy
# option (1a) but read if you wire the worker platform; harmless to leave unset.
# INNGEST_BASE_URL=
# INNGEST_SIGNING_KEY=

# ── LOCAL DEV ONLY (ignored when UPRIVER_DATA_SOURCE=supabase) ────────────────

# Root of the clients/ tree for the local filesystem data source. Defaults to
# ./clients. Has no effect in supabase mode.
# UPRIVER_CLIENTS_DIR=./clients

# ── NOTE: rate limiter ───────────────────────────────────────────────────────
# The per-token chatbot rate limit (20 writes / 60s) is HARDCODED in
# packages/dashboard/src/lib/rate-limit.ts (DEFAULT_RATE_LIMIT); there are no
# RATE_LIMIT_* env vars today. Change the limit in code, not here. The shared
# (cross-instance) counter requires the rate_limit_hit RPC + rate_limit_counters
# table — see README-deploy.md §Supabase for the migration.
