---
export interface Props {
  dimension: string;
  score: number;
  findingsCount?: number;
  href?: string;
}

const { dimension, score, findingsCount, href } = Astro.props;

function grade(s: number): string {
  if (s >= 90) return 'A';
  if (s >= 80) return 'B';
  if (s >= 70) return 'C';
  if (s >= 60) return 'D';
  return 'F';
}

function scoreColor(s: number): string {
  if (s >= 80) return 'var(--success)';
  if (s >= 60) return 'var(--accent)';
  return '#e05252';
}

const g = grade(score);
const color = scoreColor(score);
const Tag = href ? 'a' : 'div';
---

<Tag href={href} class:list={['dim-card', 'card', { linked: !!href }]}>
  <div class="dim-score" style={`color: ${color}`}>{score}</div>
  <div class="dim-grade mono" style={`color: ${color}; opacity: 0.7`}>{g}</div>
  <div class="dim-label eyebrow">{dimension}</div>
  {findingsCount !== undefined && (
    <div class="dim-findings">
      <span class="mono" style="color: var(--text-muted); font-size: var(--fs-xs)">
        {findingsCount} finding{findingsCount !== 1 ? 's' : ''}
      </span>
    </div>
  )}
</Tag>

<style>
  .dim-card {
    padding: 1.25rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.2rem;
    cursor: default;
  }

  .dim-card.linked { cursor: pointer; }

  .dim-score {
    font-family: var(--font-mono);
    font-size: 2rem;
    line-height: 1;
    font-weight: 400;
  }

  .dim-grade {
    font-size: var(--fs-xs);
    margin-bottom: 0.5rem;
  }

  .dim-label {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
  }

  .dim-findings {
    margin-top: 0.25rem;
  }
</style>
