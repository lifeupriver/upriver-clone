---
export interface Props {
  content: string;
}

const { content } = Astro.props;

// Convert basic markdown to HTML (headings, bold, code, lists, blockquotes)
// For the dashboard we use a simple regex-based converter since we control the input.
function markdownToHtml(md: string): string {
  return md
    // Headings
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/^# (.+)$/gm, '<h1>$1</h1>')
    // Bold
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    // Inline code
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    // Fenced code blocks
    .replace(/```[\w]*\n([\s\S]*?)```/g, '<pre><code>$1</code></pre>')
    // Blockquotes
    .replace(/^> (.+)$/gm, '<blockquote>$1</blockquote>')
    // Unordered lists
    .replace(/^\s*[-*] (.+)$/gm, '<li>$1</li>')
    // Ordered lists
    .replace(/^\s*\d+\. (.+)$/gm, '<li>$1</li>')
    // Horizontal rules
    .replace(/^---+$/gm, '<hr>')
    // Paragraphs (double newlines)
    .replace(/\n\n(?!<)/g, '</p><p>')
    .replace(/^(?!<)/, '<p>')
    .replace(/(?!>)$/, '</p>')
    // Wrap adjacent <li> in <ul>
    .replace(/(<li>[\s\S]*?<\/li>)(?:\s*<li>[\s\S]*?<\/li>)*/g, (m) => `<ul>${m}</ul>`)
    // Clean up empty paragraphs
    .replace(/<p>\s*<\/p>/g, '')
    .replace(/<p>(<[hb])/g, '$1')
    .replace(/(<\/h[123]>)<\/p>/g, '$1');
}

const html = markdownToHtml(content);
---

<div class="md-doc" set:html={html} />

<style>
  .md-doc {
    max-width: 72ch;
    color: var(--text-body);
    line-height: 1.75;
  }

  .md-doc :global(h1) {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: var(--fs-h3-sm);
    color: var(--text-heading);
    letter-spacing: -0.015em;
    margin: 2.5rem 0 0.75rem;
  }

  .md-doc :global(h1:first-child) { margin-top: 0; }

  .md-doc :global(h2) {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: var(--fs-xxs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 2rem 0 0.5rem;
    line-height: 1.4;
  }

  .md-doc :global(h3) {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 1.1rem;
    color: var(--text-heading);
    margin: 1.5rem 0 0.4rem;
    line-height: 1.3;
  }

  .md-doc :global(p) {
    margin-bottom: 1rem;
    font-size: var(--fs-body);
  }

  .md-doc :global(strong) {
    color: var(--text-heading);
    font-weight: 600;
  }

  .md-doc :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--bg-primary-deep);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.15em 0.4em;
    color: var(--text-body);
  }

  .md-doc :global(pre) {
    background: var(--bg-primary-deep);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin: 1rem 0;
  }

  .md-doc :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: var(--fs-sm);
    color: var(--text-body);
  }

  .md-doc :global(blockquote) {
    border-left: 4px solid var(--accent);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    background: var(--bg-surface);
    padding: 0.75rem 1.25rem;
    margin: 1rem 0;
    color: var(--text-body);
    font-style: italic;
  }

  .md-doc :global(ul) {
    padding-left: 1.25rem;
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .md-doc :global(li) {
    font-size: var(--fs-body);
    color: var(--text-body);
  }

  .md-doc :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }

  .md-doc :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: var(--fs-sm);
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .md-doc :global(th) {
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: 0.6rem 1rem;
    text-align: left;
    border-bottom: 1px solid var(--border);
  }

  .md-doc :global(td) {
    padding: 0.6rem 1rem;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 50%, transparent);
  }
</style>
