---
import type { AuditFinding } from '@upriver/core';
import { clientFacingPriority } from '@/lib/report-reader';

export interface Props {
  finding: AuditFinding;
}

const { finding } = Astro.props;

const priority = clientFacingPriority(finding.priority);

const effortLabel: Record<string, string> = {
  light: 'Light',
  medium: 'Medium',
  heavy: 'Heavy',
};
---

<details class="finding-card card" id={finding.id}>
  <summary class="finding-summary">
    <span class="finding-meta">
      <span class:list={['pill', priority.pill]}>{priority.label}</span>
      <span class="pill pill-ghost">{effortLabel[finding.effort] ?? finding.effort}</span>
    </span>
    <h3 class="finding-title">{finding.title}</h3>
    <span class="finding-toggle" aria-hidden="true">+</span>
  </summary>

  <div class="finding-body">
    <p class="finding-desc">{finding.description}</p>

    {finding.why_it_matters && (
      <p class="finding-why">{finding.why_it_matters}</p>
    )}

    {finding.recommendation && (
      <div class="quote-block finding-rec">
        <strong style="color: var(--text-heading); display: block; margin-bottom: 0.3rem; font-family: var(--font-heading); font-size: var(--fs-xs); letter-spacing: 0.06em; text-transform: uppercase;">Recommendation</strong>
        {finding.recommendation}
      </div>
    )}

    {finding.page && (
      <div class="finding-page">
        <span class="mono" style="color: var(--text-muted); font-size: var(--fs-xs)">
          Page: {finding.page}
        </span>
      </div>
    )}
  </div>
</details>

<style>
  .finding-card {
    padding: 0;
    overflow: hidden;
  }

  .finding-summary {
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1.25rem;
    transition: background var(--dur-fast) var(--ease-out);
  }
  .finding-summary::-webkit-details-marker { display: none; }
  .finding-summary:hover { background: var(--bg-surface-hover); }

  .finding-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
  }

  .finding-title {
    flex: 1;
    margin: 0;
    font-size: 1rem;
    line-height: 1.3;
  }

  .finding-toggle {
    flex-shrink: 0;
    color: var(--text-muted);
    font-size: 1.1rem;
    line-height: 1;
    width: 1.25rem;
    text-align: center;
  }

  details[open] > .finding-summary { border-bottom: 1px solid var(--border); }
  details[open] > .finding-summary > .finding-toggle { transform: rotate(45deg); color: var(--accent); }

  .finding-body {
    padding: 1rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .finding-desc {
    color: var(--text-body);
    font-size: var(--fs-sm);
    line-height: 1.65;
    margin: 0;
  }

  .finding-why {
    color: var(--text-muted);
    font-size: var(--fs-sm);
    font-style: italic;
    margin: 0;
  }

  .finding-rec {
    margin-top: 0.25rem;
    font-size: var(--fs-sm);
    line-height: 1.6;
  }

  .finding-page {
    padding-top: 0.5rem;
    border-top: 1px solid var(--border);
  }

  @media print {
    .finding-toggle { display: none; }
    .finding-summary { padding-bottom: 0.5rem; border-bottom: 1px solid #ccc; }
    /* Force every card open in printed PDFs even when collapsed on screen. */
    details.finding-card > .finding-body,
    details.finding-card > *:not(summary) { display: block !important; }
  }
</style>
