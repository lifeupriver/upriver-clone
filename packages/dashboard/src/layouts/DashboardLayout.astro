---
import '../styles/global.css';
import { getSessionUser } from '@/lib/auth';
import { getDataSource } from '@/lib/data-source';
import {
  clientExists,
  getClientArtifacts,
  readClientConfig,
  type ClientArtifacts,
} from '@/lib/fs-reader';

export interface Props {
  title: string;
  /** Highlight a nav section: 'clients' | 'deliverables' */
  section?: string;
}

const { title, section = 'clients' } = Astro.props;
const currentPath = Astro.url.pathname;

// In supabase (hosted) mode, surface the signed-in operator email and a
// sign-out link in the sidebar footer. Local mode skips the lookup —
// there's no Supabase session to read and the env vars may not be set.
const isHosted = getDataSource() === 'supabase';
const sessionUser = isHosted ? await getSessionUser(Astro.request, Astro.cookies) : null;
const operatorEmail = sessionUser?.email ?? null;

const nav = [
  { href: '/clients', label: 'Clients', section: 'clients' },
  { href: '/deliverables', label: 'Deliverables', section: 'deliverables' },
];

// When the current URL is /clients/<slug>/... or /deliverables/<slug>/...,
// surface a per-client sub-nav with status dots so the operator doesn't have
// to bounce back to the landing page to jump between artifacts.
const segments = currentPath.split('/').filter(Boolean);
const slugFromPath =
  (segments[0] === 'clients' || segments[0] === 'deliverables') && segments[1] && segments[1] !== 'new' && segments[1] !== 'expired'
    ? segments[1]
    : null;

interface SubNavItem {
  href: string;
  label: string;
  has: boolean;
}

let clientSubNav: { name: string; slug: string; items: SubNavItem[] } | null = null;
if (slugFromPath && (await clientExists(slugFromPath))) {
  const [config, artifacts] = await Promise.all([
    readClientConfig(slugFromPath),
    getClientArtifacts(slugFromPath),
  ]);
  if (config) {
    const a: ClientArtifacts = artifacts;
    clientSubNav = {
      name: config.name,
      slug: slugFromPath,
      items: [
        { href: `/clients/${slugFromPath}`,                  label: 'Overview',         has: true },
        { href: `/clients/${slugFromPath}/intake`,           label: 'Intake',           has: a.hasIntake },
        { href: `/clients/${slugFromPath}/audit`,            label: 'Audit',            has: a.hasAudit },
        { href: `/clients/${slugFromPath}/clone-fidelity`,   label: 'Clone Fidelity',   has: a.hasFidelity },
        { href: `/clients/${slugFromPath}/voice`,            label: 'Brand Voice',      has: a.hasVoice },
        { href: `/clients/${slugFromPath}/design-brief`,     label: 'Design Brief',     has: a.hasBrief },
        { href: `/clients/${slugFromPath}/site`,             label: 'Site Preview',     has: a.hasRepo },
        { href: `/clients/${slugFromPath}/fixes`,            label: 'Fixes Plan',       has: a.hasFixes },
        { href: `/clients/${slugFromPath}/qa`,               label: 'QA Report',        has: a.hasQa },
        { href: `/clients/${slugFromPath}/launch-checklist`, label: 'Launch Checklist', has: a.hasLaunch },
        { href: `/deliverables/${slugFromPath}`,             label: 'Export Audit',     has: a.hasAudit },
        { href: `/deliverables/${slugFromPath}/design-brief`, label: 'Export Brief',    has: a.hasBrief },
        { href: `/clients/${slugFromPath}/share`,            label: 'Share Links',      has: true },
      ],
    };
  }
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Upriver Dashboard</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="shell">
      <!-- Sidebar -->
      <aside class="sidebar">
        <a href="/clients" class="brand">
          <svg width="22" height="20" viewBox="0 0 40 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M20 2 L38 34 H22 L20 28 L18 34 H2 Z" stroke="#F1551A" stroke-width="2.5" stroke-linejoin="round" fill="none"/>
            <path d="M12 34 L20 14 L28 34" stroke="#F1551A" stroke-width="2.5" stroke-linejoin="round" fill="none"/>
          </svg>
          <span class="brand-name">Upriver</span>
        </a>

        <nav class="sidebar-nav">
          <span class="eyebrow nav-section-label">Navigation</span>
          {nav.map(item => (
            <a
              href={item.href}
              class:list={['nav-link', { active: currentPath.startsWith(item.href) }]}
            >
              {item.label}
            </a>
          ))}
        </nav>

        {clientSubNav && (
          <nav class="sidebar-subnav">
            <span class="eyebrow nav-section-label">This client</span>
            <span class="sub-name" title={clientSubNav.name}>{clientSubNav.name}</span>
            {clientSubNav.items.map(item => (
              <a
                href={item.href}
                class:list={['sub-link', { active: currentPath === item.href, dim: !item.has }]}
              >
                <span class:list={['sub-dot', { has: item.has }]} aria-hidden="true" />
                <span class="sub-label">{item.label}</span>
              </a>
            ))}
          </nav>
        )}

        <div class="sidebar-footer">
          {operatorEmail && (
            <div class="session-block">
              <span class="eyebrow session-label">Signed in</span>
              <span class="session-email" title={operatorEmail}>{operatorEmail}</span>
              <a href="/auth/signout" class="signout-link">Sign out</a>
            </div>
          )}
          <span class="mono version-tag">v0.1.0</span>
        </div>
      </aside>

      <!-- Main -->
      <main class="main">
        <slot />
      </main>
    </div>
  </body>
</html>

<style>
  .shell {
    display: flex;
    min-height: 100vh;
  }

  .sidebar {
    width: 220px;
    flex-shrink: 0;
    background: var(--bg-primary-deep);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 1.25rem 1.25rem 1rem;
    border-bottom: 1px solid var(--border);
  }

  .brand-name {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 1rem;
    color: var(--text-heading);
    letter-spacing: -0.01em;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    padding: 1rem 0 0.5rem;
    gap: 0.125rem;
  }

  .nav-section-label {
    padding: 0 1.25rem 0.5rem;
  }

  .sidebar-subnav {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    padding: 0.5rem 0 0.5rem;
    margin-top: 0.75rem;
    border-top: 1px solid var(--border);
  }

  .sidebar-subnav .nav-section-label {
    padding: 0.75rem 1.25rem 0.25rem;
  }

  .sub-name {
    padding: 0 1.25rem 0.5rem;
    color: var(--text-body);
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .sub-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 1.25rem;
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-muted);
    border-left: 2px solid transparent;
    transition: color var(--dur-fast) var(--ease-out),
                border-color var(--dur-fast) var(--ease-out),
                background var(--dur-fast) var(--ease-out);
  }

  .sub-link:hover { color: var(--text-body); background: var(--bg-surface); }
  .sub-link.active { color: var(--accent); border-left-color: var(--accent); }
  .sub-link.dim { opacity: 0.55; }

  .sub-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
    border: 1px solid var(--border);
    background: transparent;
  }
  .sub-dot.has {
    background: var(--success);
    border-color: var(--success);
  }

  .sub-label {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .sidebar-footer {
    margin-top: auto;
    padding: 1rem 1.25rem;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .session-block {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .session-label {
    margin-bottom: 0.125rem;
  }

  .session-email {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--text-body);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .signout-link {
    align-self: flex-start;
    margin-top: 0.125rem;
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: var(--fs-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    transition: color 150ms var(--ease-out);
  }

  .signout-link:hover {
    color: var(--accent);
  }

  .version-tag {
    font-size: var(--fs-xs);
    color: var(--text-muted);
    opacity: 0.7;
  }

  .main {
    flex: 1;
    min-width: 0;
    padding: 2rem 2.5rem;
    max-width: 1400px;
  }
</style>
