---
import ReportLayout from '@/layouts/ReportLayout.astro';
import IntakeForm from '@/components/react/IntakeForm';
import { readClientConfig, clientExists, readIntake } from '@/lib/fs-reader';
import { readAuditPackage } from '@/lib/report-reader';

const { slug } = Astro.params;

if (!slug || !clientExists(slug)) {
  return Astro.redirect('/clients');
}

const config = readClientConfig(slug)!;
const auditPackage = readAuditPackage(slug);

if (!auditPackage) {
  return Astro.redirect('/clients');
}

const existingIntake = readIntake(slug) ?? undefined;

const mappedFindings = auditPackage.findings.map(f => ({
  id: f.id,
  title: f.title,
  priority: f.priority,
}));

const mappedPages = auditPackage.siteStructure.pages.map(p => ({
  slug: p.slug,
  title: p.title,
  url: p.url,
}));

interface ScopeTier {
  name: string;
  price: string;
  scope: string;
  description: string;
}

const tiers: ScopeTier[] = [
  {
    name: 'Polish',
    price: '$2,800',
    scope: '2-week project',
    description:
      'Fix every critical finding in this audit on your existing platform — no replatform, no design changes. For sites that mostly work but have a handful of issues blocking conversions or search visibility.',
  },
  {
    name: 'Rebuild',
    price: '$9,500',
    scope: '4–6 week build',
    description:
      'Start fresh on a fast, modern stack with every P0 and P1 finding resolved as we build. The new site scores measurably higher on technical and SEO audits the day it ships.',
  },
  {
    name: 'Rebuild + content',
    price: '$18,500',
    scope: '6–8 week engagement',
    description:
      'Everything in Rebuild plus a copy rewrite informed by your brand voice and a programmatic-SEO layer that publishes pillar content alongside the new site. For venues and service businesses that want to compete on search.',
  },
];
---

<ReportLayout
  slug={slug}
  clientName={config.name}
  currentTab="next-steps"
  title={`${config.name} — Next steps`}
>
  <header class="page-header">
    <span class="eyebrow">Next steps</span>
    <h1>What we'd do about it</h1>
  </header>

  <section class="tiers">
    {tiers.map(t => (
      <div class="card tier-card">
        <div class="tier-head">
          <h3 class="tier-name">{t.name}</h3>
          <span class="tier-price">{t.price}</span>
        </div>
        <span class="eyebrow tier-scope">{t.scope}</span>
        <p class="tier-desc">{t.description}</p>
      </div>
    ))}
  </section>

  <section class="intake">
    <div class="card intake-card">
      <IntakeForm
        client:load
        slug={slug}
        clientName={config.name}
        findings={mappedFindings}
        pages={mappedPages}
        initial={existingIntake}
      />
    </div>
  </section>
</ReportLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    margin: 0.25rem 0 0.375rem;
  }

  .tiers {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .tier-card {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .tier-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .tier-name {
    font-size: 1.15rem;
    margin: 0;
  }

  .tier-price {
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .tier-scope {
    font-size: 0.7rem;
  }

  .tier-desc {
    color: var(--text-body);
    font-size: var(--fs-sm);
    line-height: 1.6;
    margin-top: 0.25rem;
  }

  .intake-card {
    padding: 1.75rem;
  }

  @media print {
    body { background: white !important; color: #111 !important; }
    .page-header { page-break-before: always; }
    .tiers,
    .intake {
      page-break-inside: avoid;
    }
  }
</style>
