---
import ReportLayout from '@/layouts/ReportLayout.astro';
import IntakeForm from '@/components/react/IntakeForm';
import { readClientConfig, clientExists, readIntake } from '@/lib/fs-reader';
import { readAuditPackage } from '@/lib/report-reader';
import { deliverableHref, missingDeliverableRedirect } from '@/lib/deliverable-links';
import { resolvePricingTiers } from '@/lib/pricing';

const { slug } = Astro.params;

// Share token from the portal link (`?t=…`). The middleware validated it to
// let this page render at all; internal redirects must carry it, and
// IntakeForm passes it back on its /api/intake calls so the
// (operator-or-token) in-handler gate authorizes the client.
const shareToken = Astro.url.searchParams.get('t');

if (!slug) {
  return Astro.redirect('/clients');
}
if (!(await clientExists(slug))) {
  return Astro.redirect(shareToken ? deliverableHref(slug, '/not-ready', shareToken) : '/clients');
}

const config = (await readClientConfig(slug))!;
const auditPackage = await readAuditPackage(slug);

if (!auditPackage) {
  // Token holders get the branded "not ready yet" page; operators keep their
  // workspace redirect.
  return Astro.redirect(missingDeliverableRedirect(slug, shareToken));
}

const existingIntake = (await readIntake(slug)) ?? undefined;

const mappedFindings = auditPackage.findings.map(f => ({
  id: f.id,
  title: f.title,
  priority: f.priority,
}));

const mappedPages = auditPackage.siteStructure.pages.map(p => ({
  slug: p.slug,
  title: p.title,
  url: p.url,
}));

// Engagement tiers: per-client `pricing:` from client-config.yaml when
// present and well-formed, otherwise the built-in defaults (the values that
// used to be hard-coded here).
const tiers = resolvePricingTiers(config);
---

<ReportLayout
  slug={slug}
  clientName={config.name}
  currentTab="next-steps"
  title={`${config.name} — Next steps`}
>
  <header class="page-header">
    <span class="eyebrow">Next steps</span>
    <h1>What we'd do about it</h1>
  </header>

  <section class="tiers">
    {tiers.map(t => (
      <div class="card tier-card">
        <div class="tier-head">
          <h3 class="tier-name">{t.name}</h3>
          <span class="tier-price">{t.price}</span>
        </div>
        <span class="eyebrow tier-scope">{t.scope}</span>
        <p class="tier-desc">{t.description}</p>
      </div>
    ))}
  </section>

  <section class="intake">
    <div class="card intake-card">
      <IntakeForm
        client:load
        slug={slug}
        clientName={config.name}
        findings={mappedFindings}
        pages={mappedPages}
        initial={existingIntake}
        shareToken={shareToken}
      />
    </div>
  </section>
</ReportLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    margin: 0.25rem 0 0.375rem;
  }

  .tiers {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .tier-card {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .tier-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .tier-name {
    font-size: 1.15rem;
    margin: 0;
  }

  .tier-price {
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .tier-scope {
    font-size: 0.7rem;
  }

  .tier-desc {
    color: var(--text-body);
    font-size: var(--fs-sm);
    line-height: 1.6;
    margin-top: 0.25rem;
  }

  .intake-card {
    padding: 1.75rem;
  }

  @media print {
    body { background: white !important; color: #111 !important; }
    .page-header { page-break-before: always; }
    .tiers,
    .intake {
      page-break-inside: avoid;
    }
  }
</style>
