---
import ReportLayout from '@/layouts/ReportLayout.astro';
import { readClientConfig, clientExists } from '@/lib/fs-reader';
import { readAuditPackage } from '@/lib/report-reader';

const { slug } = Astro.params;

if (!slug || !clientExists(slug)) {
  return Astro.redirect('/clients');
}

const config = readClientConfig(slug)!;
const auditPackage = readAuditPackage(slug);

if (!auditPackage) {
  return Astro.redirect('/clients');
}

interface ScopeTier {
  name: string;
  price: string;
  scope: string;
  description: string;
}

// TODO(roadmap): pricing copy
const tiers: ScopeTier[] = [
  {
    name: 'Polish',
    price: 'Contact us',
    scope: '2-week scope',
    description: 'Fix the critical findings only. Your existing site stays in place.',
  },
  {
    name: 'Rebuild',
    price: 'Contact us',
    scope: '4-6 week scope',
    description: 'Replatform to Astro and apply every recommended fix as we go.',
  },
  {
    name: 'Rebuild + content',
    price: 'Contact us',
    scope: '6-8 week scope',
    description: 'Everything in Rebuild plus a copy and SEO improvement layer.',
  },
];

const intakeMailto =
  `mailto:hello@upriver.com?subject=Audit%20intake%20for%20${encodeURIComponent(config.name)}`;
---

<ReportLayout
  slug={slug}
  clientName={config.name}
  currentTab="next-steps"
  title={`${config.name} — Next steps`}
>
  <header class="page-header">
    <span class="eyebrow">Next steps</span>
    <h1>What we'd do about it</h1>
  </header>

  <section class="tiers">
    {tiers.map(t => (
      <div class="card tier-card">
        <div class="tier-head">
          <h3 class="tier-name">{t.name}</h3>
          <span class="tier-price">{t.price}</span>
        </div>
        <span class="eyebrow tier-scope">{t.scope}</span>
        <p class="tier-desc">{t.description}</p>
      </div>
    ))}
  </section>

  {/* TODO(roadmap): B replace with embedded IntakeForm */}
  <section class="intake">
    <div class="card intake-card">
      <div class="intake-copy">
        <h3>Tell us what to fix</h3>
        <p>
          Walk through the findings and mark which ones matter to you. Takes about 5 minutes.
        </p>
      </div>
      <a href={intakeMailto} class="intake-btn">Start intake</a>
    </div>
  </section>
</ReportLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    margin: 0.25rem 0 0.375rem;
  }

  .tiers {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .tier-card {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .tier-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .tier-name {
    font-size: 1.15rem;
    margin: 0;
  }

  .tier-price {
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .tier-scope {
    font-size: 0.7rem;
  }

  .tier-desc {
    color: var(--text-body);
    font-size: var(--fs-sm);
    line-height: 1.6;
    margin-top: 0.25rem;
  }

  .intake-card {
    padding: 1.75rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .intake-copy {
    max-width: 48ch;
  }

  .intake-copy h3 {
    margin-bottom: 0.25rem;
  }

  .intake-copy p {
    color: var(--text-muted);
    font-size: var(--fs-sm);
    line-height: 1.6;
  }

  .intake-btn {
    padding: 0.65rem 1.1rem;
    background: var(--accent);
    color: #fff;
    border-radius: var(--radius-sm);
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    box-shadow: var(--shadow-btn-primary);
    transition: background var(--dur-fast) var(--ease-out);
  }

  .intake-btn:hover {
    background: var(--accent-hover);
  }

  @media print {
    body { background: white !important; color: #111 !important; }
    .page-header { page-break-before: always; }
    .tiers,
    .intake {
      page-break-inside: avoid;
    }
  }
</style>
