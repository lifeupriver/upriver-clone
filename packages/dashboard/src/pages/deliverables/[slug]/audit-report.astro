---
import DeliverableLayout from '@/layouts/DeliverableLayout.astro';
import DimensionScoreCard from '@/components/astro/DimensionScoreCard.astro';
import FindingCard from '@/components/astro/FindingCard.astro';
import { ScoreRadar } from '@/components/react/ScoreRadar';
import {
  readClientConfig,
  readAuditPasses,
  readAuditSummary,
  clientExists,
} from '@/lib/fs-reader';
import type { AuditFinding } from '@upriver/core';

const { slug } = Astro.params;

if (!slug || !clientExists(slug)) {
  return Astro.redirect('/clients');
}

const config = readClientConfig(slug)!;
const passes = readAuditPasses(slug);
const summary = readAuditSummary(slug);

if (passes.length === 0) {
  return Astro.redirect(`/clients/${slug}`);
}

const scores = Object.fromEntries(passes.map(p => [p.dimension, p.score]));
const allFindings: AuditFinding[] = passes.flatMap(p => p.findings);
const p0 = allFindings.filter(f => f.priority === 'p0');
const p1 = allFindings.filter(f => f.priority === 'p1');

const date = new Date().toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---

<DeliverableLayout
  title={`${config.name} — Audit Report`}
  clientName={config.name}
  docType="Audit Report"
  slug={slug}
>
  <!-- Cover -->
  <div class="cover">
    <div class="cover-logo">
      <svg width="32" height="30" viewBox="0 0 40 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Upriver">
        <path d="M20 2 L38 34 H22 L20 28 L18 34 H2 Z" stroke="#F1551A" stroke-width="2.5" stroke-linejoin="round" fill="none"/>
        <path d="M12 34 L20 14 L28 34" stroke="#F1551A" stroke-width="2.5" stroke-linejoin="round" fill="none"/>
      </svg>
      <span class="cover-brand">Upriver Consulting</span>
    </div>

    <div class="cover-body">
      <span class="eyebrow">Website Audit Report</span>
      <h1 class="cover-title">{config.name}</h1>
      <p class="cover-url mono">{config.url}</p>
      <p class="cover-date" style="color: var(--text-muted); font-size: var(--fs-sm);">{date}</p>
    </div>

    {summary && (
      <div class="cover-score">
        <span class="eyebrow">Overall Score</span>
        <span class="cover-score-num score-num">{summary.overall}</span>
        <div class="cover-counts">
          <span class="pill pill-accent">{summary.p0_count} P0</span>
          <span class="pill pill-muted">{summary.p1_count} P1</span>
          <span class="pill pill-ghost">{summary.p2_count} P2</span>
        </div>
      </div>
    )}
  </div>

  <!-- Score matrix -->
  <section class="report-section">
    <h2>Scores by Dimension</h2>
    <div class="score-grid">
      {passes.map(p => (
        <DimensionScoreCard
          dimension={p.dimension}
          score={p.score}
          findingsCount={p.findings.length}
        />
      ))}
    </div>
  </section>

  <!-- Radar chart -->
  <section class="report-section radar-section">
    <h2>Score Radar</h2>
    <div class="radar-wrap">
      <ScoreRadar client:load scores={scores} size={300} />
    </div>
  </section>

  <!-- Findings by dimension -->
  {passes.map(pass => (
    <section class="report-section" id={pass.dimension}>
      <h2>{pass.dimension} — {pass.score}</h2>
      {pass.summary && (
        <p class="dim-summary">{pass.summary}</p>
      )}
      {pass.findings.length === 0 ? (
        <p style="color: var(--success); font-size: var(--fs-sm);">No findings in this dimension.</p>
      ) : (
        <div class="findings-list">
          {[...pass.findings]
            .sort((a, b) => {
              const order = { p0: 0, p1: 1, p2: 2 };
              return (order[a.priority] ?? 3) - (order[b.priority] ?? 3);
            })
            .map(f => (
              <FindingCard finding={f} />
            ))
          }
        </div>
      )}
    </section>
  ))}
</DeliverableLayout>

<style>
  .cover {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-bottom: 3rem;
    margin-bottom: 3rem;
    border-bottom: 1px solid var(--border);
  }

  .cover-logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .cover-brand {
    font-family: var(--font-heading);
    font-weight: 500;
    color: var(--text-heading);
    font-size: 0.9rem;
  }

  .cover-body {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .cover-title {
    font-size: 3rem;
    letter-spacing: -0.025em;
    margin: 0.25rem 0 0.25rem;
  }

  .cover-url { color: var(--text-muted); font-size: var(--fs-sm); }

  .cover-score {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cover-score-num { font-size: 4rem; }

  .cover-counts {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .report-section {
    margin-bottom: 3rem;
  }

  .report-section h2 {
    font-size: var(--fs-xxs);
    margin-bottom: 1.25rem;
    padding-bottom: 0.625rem;
    border-bottom: 1px solid var(--border);
  }

  .score-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: 0.75rem;
  }

  .radar-section { text-align: center; }
  .radar-wrap { display: inline-block; }

  .dim-summary {
    color: var(--text-body);
    font-size: var(--fs-sm);
    margin-bottom: 1rem;
    max-width: 65ch;
    line-height: 1.65;
  }

  .findings-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  @media print {
    .report-section { page-break-inside: avoid; }
    .cover { page-break-after: always; }
  }
</style>
