---
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import ReportLayout from '@/layouts/ReportLayout.astro';
import DimensionScoreCard from '@/components/astro/DimensionScoreCard.astro';
import { ScoreRadar } from '@/components/react/ScoreRadar';
import { readClientConfig, readAuditPasses, clientExists, getClientsBase } from '@/lib/fs-reader';
import { readAuditPackage } from '@/lib/report-reader';

const { slug } = Astro.params;

if (!slug || !clientExists(slug)) {
  return Astro.redirect('/clients');
}

const config = readClientConfig(slug)!;
const passes = readAuditPasses(slug);
const auditPackage = readAuditPackage(slug);

if (!auditPackage) {
  return Astro.redirect('/clients');
}

const scores = Object.fromEntries(passes.map(p => [p.dimension, p.score]));

const topPages = [...auditPackage.siteStructure.pages]
  .sort((a, b) => b.wordCount - a.wordCount)
  .slice(0, 6);

const clientsBase = getClientsBase();

interface PageSnapshot {
  slug: string;
  title: string;
  url: string;
  hasShot: boolean;
}

const snapshots: PageSnapshot[] = topPages.map(p => {
  const shotPath = join(clientsBase, slug, 'screenshots', 'desktop', `${p.slug}.png`);
  return {
    slug: p.slug,
    title: p.title,
    url: p.url,
    hasShot: existsSync(shotPath),
  };
});
---

<ReportLayout
  slug={slug}
  clientName={config.name}
  currentTab="scorecard"
  title={`${config.name} — Scorecard`}
>
  <header class="page-header">
    <span class="eyebrow">Scorecard</span>
    <h1>How your site scores</h1>
  </header>

  {passes.length > 0 ? (
    <>
      <section class="radar-section">
        <h2 class="section-h">Overall</h2>
        <div class="radar-wrap">
          <ScoreRadar client:load scores={scores} size={300} />
        </div>
      </section>

      <section class="grid-section">
        <h2 class="section-h">Dimensions</h2>
        <div class="score-grid">
          {passes.map(p => (
            <DimensionScoreCard
              dimension={p.dimension}
              score={p.score}
              findingsCount={p.findings.length}
            />
          ))}
        </div>
      </section>
    </>
  ) : (
    <p class="empty">No audit data available yet.</p>
  )}

  {snapshots.length > 0 && (
    <section class="snapshots-section">
      <h2 class="section-h">Page snapshots</h2>
      <div class="snapshot-grid">
        {snapshots.map(s => (
          <div class="snapshot card">
            {/* TODO(roadmap): A.2 wire screenshot serving */}
            <div
              class:list={['snapshot-thumb', { 'snapshot-thumb-empty': !s.hasShot }]}
              aria-hidden="true"
            >
              <span class="snapshot-thumb-label">{s.title}</span>
            </div>
            <div class="snapshot-meta">
              <h3 class="snapshot-title">{s.title}</h3>
              <p class="mono snapshot-url">{s.url}</p>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}
</ReportLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    margin: 0.25rem 0 0.375rem;
  }

  .section-h {
    font-size: var(--fs-xxs);
    margin-bottom: 1.25rem;
    padding-bottom: 0.625rem;
    border-bottom: 1px solid var(--border);
  }

  .radar-section {
    text-align: center;
    margin-bottom: 3rem;
  }

  .radar-wrap {
    display: inline-block;
  }

  .grid-section {
    margin-bottom: 3rem;
  }

  .score-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: 0.75rem;
  }

  .snapshots-section {
    margin-bottom: 3rem;
  }

  .snapshot-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }

  .snapshot {
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .snapshot-thumb {
    aspect-ratio: 16 / 10;
    background: linear-gradient(
      135deg,
      var(--bg-primary-deep) 0%,
      var(--bg-surface) 100%
    );
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem;
  }

  .snapshot-thumb-empty {
    opacity: 0.7;
  }

  .snapshot-thumb-label {
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-align: center;
    line-height: 1.3;
  }

  .snapshot-meta {
    padding: 0.75rem 1rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .snapshot-title {
    font-size: 0.95rem;
    line-height: 1.3;
  }

  .snapshot-url {
    color: var(--text-muted);
    font-size: var(--fs-xs);
    word-break: break-all;
  }

  .empty {
    color: var(--text-muted);
    font-size: var(--fs-sm);
  }

  @media print {
    body { background: white !important; color: #111 !important; }
    .page-header { page-break-before: always; }
    .radar-section,
    .grid-section,
    .snapshots-section {
      page-break-inside: avoid;
    }
  }
</style>
