---
import DeliverableLayout from '@/layouts/DeliverableLayout.astro';
import MarkdownDoc from '@/components/astro/MarkdownDoc.astro';
import { readClientConfig, readMarkdownFile, clientExists } from '@/lib/fs-reader';
import { deliverableHref } from '@/lib/deliverable-links';

const { slug } = Astro.params;

// Share token from the portal link (`?t=`); internal redirects must carry it.
const token = Astro.url.searchParams.get('t');

if (!slug) {
  return Astro.redirect('/clients');
}
if (!(await clientExists(slug))) {
  return Astro.redirect(token ? deliverableHref(slug, '/not-ready', token) : '/clients');
}

const config = (await readClientConfig(slug))!;
const content = await readMarkdownFile(slug, 'claude-design-brief.md');

if (!content) {
  // Token holders get the branded "not ready yet" page; operators keep their
  // workspace redirect.
  return Astro.redirect(
    token ? deliverableHref(slug, '/not-ready', token) : `/clients/${slug}/design-brief`,
  );
}
---

<DeliverableLayout
  title={`${config.name} — Design Brief`}
  clientName={config.name}
  docType="Design Brief"
  slug={slug}
>
  <!-- Cover -->
  <div class="cover">
    <div class="cover-logo">
      <svg width="32" height="30" viewBox="0 0 40 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Upriver">
        <path d="M20 2 L38 34 H22 L20 28 L18 34 H2 Z" stroke="#F1551A" stroke-width="2.5" stroke-linejoin="round" fill="none"/>
        <path d="M12 34 L20 14 L28 34" stroke="#F1551A" stroke-width="2.5" stroke-linejoin="round" fill="none"/>
      </svg>
      <span class="cover-brand">Upriver Consulting</span>
    </div>
    <div>
      <span class="eyebrow">Design Brief</span>
      <h1 class="cover-title">{config.name}</h1>
    </div>
  </div>

  <!-- Brief content -->
  <MarkdownDoc content={content} collapseSections />
</DeliverableLayout>

<style>
  .cover {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .cover-logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .cover-brand {
    font-family: var(--font-heading);
    font-weight: 500;
    color: var(--text-heading);
    font-size: 0.9rem;
  }

  .cover-title {
    font-size: 2.5rem;
    letter-spacing: -0.02em;
    margin: 0.25rem 0 0;
  }
</style>
