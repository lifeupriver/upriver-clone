---
import ReportLayout from '@/layouts/ReportLayout.astro';
import CoverHeader from '@/components/astro/CoverHeader.astro';
import {
  readClientConfig,
  readAuditPasses,
  readAuditSummary,
  clientExists,
} from '@/lib/fs-reader';
import { readAuditPackage, readExecutiveSummary } from '@/lib/report-reader';

const { slug } = Astro.params;

if (!slug || !(await clientExists(slug))) {
  return Astro.redirect('/clients');
}

const config = (await readClientConfig(slug))!;
const summary = await readAuditSummary(slug);
const passes = await readAuditPasses(slug);
const auditPackage = await readAuditPackage(slug);

if (!auditPackage) {
  return Astro.redirect('/clients');
}

const executiveSummary = await readExecutiveSummary(slug);

const date = new Date().toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const totalFindings = summary?.total_findings ?? auditPackage.meta.totalFindings;
const p0Count = summary?.p0_count ?? auditPackage.meta.findingsByPriority.p0;
const overall = summary?.overall ?? auditPackage.meta.overallScore;

const dimensionsBelowThreshold = passes.filter(p => p.score < 80).length;

const heroMetrics = (auditPackage.impactMetrics?.metrics ?? []).slice(0, 3);

/**
 * Split a markdown body on `\n## ` boundaries so each chunk represents a
 * leading heading followed by its prose. The first chunk may be a preamble
 * with no heading.
 */
interface NarrativeBlock {
  heading: string | null;
  body: string;
}

function splitNarrative(md: string): NarrativeBlock[] {
  const trimmed = md.trim();
  if (trimmed.length === 0) return [];
  const parts = trimmed.split(/\n## /);
  const blocks: NarrativeBlock[] = [];
  parts.forEach((part, idx) => {
    if (idx === 0) {
      // Preamble may already start with `## `; strip it consistently.
      const cleaned = part.replace(/^##\s+/, '');
      const firstNl = cleaned.indexOf('\n');
      if (/^[A-Z]/.test(cleaned) && firstNl > 0 && firstNl < 120) {
        blocks.push({
          heading: cleaned.slice(0, firstNl).trim(),
          body: cleaned.slice(firstNl + 1).trim(),
        });
      } else {
        blocks.push({ heading: null, body: cleaned.trim() });
      }
      return;
    }
    const firstNl = part.indexOf('\n');
    if (firstNl === -1) {
      blocks.push({ heading: part.trim(), body: '' });
    } else {
      blocks.push({
        heading: part.slice(0, firstNl).trim(),
        body: part.slice(firstNl + 1).trim(),
      });
    }
  });
  return blocks.filter(b => (b.heading && b.heading.length > 0) || b.body.length > 0);
}

const narrativeBlocks = executiveSummary ? splitNarrative(executiveSummary) : [];
---

<ReportLayout
  slug={slug}
  clientName={config.name}
  currentTab="overview"
  title={`${config.name} — Audit Report`}
>
  <CoverHeader
    clientName={config.name}
    clientUrl={config.url}
    date={date}
    overallScore={overall}
    branding={auditPackage.brandingProfile}
  />

  <section class="stats">
    {heroMetrics.length > 0 ? (
      heroMetrics.map(metric => (
        <div class="card stat-card">
          <span class="stat-num score-num">{metric.display || String(metric.value)}</span>
          <span class="stat-label">{metric.label}</span>
          <span class="stat-rationale">{metric.rationale}</span>
        </div>
      ))
    ) : (
      <>
        <div class="card stat-card">
          <span class="stat-num score-num">{p0Count}</span>
          <span class="stat-label">Critical issues blocking growth</span>
        </div>
        <div class="card stat-card">
          <span class="stat-num score-num">{dimensionsBelowThreshold}</span>
          <span class="stat-label">Dimensions below shippable threshold</span>
        </div>
        <div class="card stat-card">
          <span class="stat-num score-num">{totalFindings}</span>
          <span class="stat-label">Total opportunities identified</span>
        </div>
      </>
    )}
  </section>

  <section class="narrative">
    <span class="eyebrow">Executive summary</span>
    {narrativeBlocks.length > 0 ? (
      narrativeBlocks.map(block => (
        <div class="narrative-block">
          {block.heading && <h3>{block.heading}</h3>}
          {block.body && <p>{block.body}</p>}
        </div>
      ))
    ) : (
      <p class="narrative-fallback">
        Detailed narrative will appear here once synthesis completes.
      </p>
    )}
  </section>

  <section class="cta">
    <div class="card cta-card">
      <div class="cta-copy">
        <h3>Ready to act on this?</h3>
        <p>Walk through the recommended fixes and pick the scope that fits.</p>
      </div>
      <a href={`/deliverables/${slug}/next-steps`} class="cta-btn">
        See what we'd do about it
      </a>
    </div>
  </section>
</ReportLayout>

<style>
  .stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .stat-card {
    padding: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .stat-num {
    font-size: 2.5rem;
    line-height: 1;
  }

  .stat-label {
    color: var(--text-muted);
    font-size: var(--fs-sm);
    line-height: 1.4;
  }

  .stat-rationale {
    color: var(--text-muted);
    font-size: var(--fs-xs);
    line-height: 1.5;
    opacity: 0.85;
    margin-top: 0.25rem;
  }

  .narrative {
    margin-bottom: 3rem;
  }

  .narrative .eyebrow {
    display: block;
    margin-bottom: 1rem;
  }

  .narrative-block {
    margin-bottom: 1.5rem;
    max-width: 72ch;
  }

  .narrative-block h3 {
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
  }

  .narrative-block p {
    color: var(--text-body);
    font-size: var(--fs-body);
    line-height: 1.7;
    white-space: pre-wrap;
  }

  .narrative-fallback {
    color: var(--text-muted);
    font-size: var(--fs-sm);
    max-width: 65ch;
  }

  .cta-card {
    padding: 1.75rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .cta-copy h3 {
    margin-bottom: 0.25rem;
  }

  .cta-copy p {
    color: var(--text-muted);
    font-size: var(--fs-sm);
  }

  .cta-btn {
    padding: 0.65rem 1.1rem;
    background: var(--accent);
    color: #fff;
    border-radius: var(--radius-sm);
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    box-shadow: var(--shadow-btn-primary);
    transition: background var(--dur-fast) var(--ease-out);
  }

  .cta-btn:hover {
    background: var(--accent-hover);
  }

  @media print {
    body { background: white !important; color: #111 !important; }
    .stats, .narrative { page-break-inside: avoid; }
  }
</style>
