---
import MessageLayout from '@/layouts/MessageLayout.astro';
---

<MessageLayout title="Share link expired" clientFacing={true}>
  <span class="eyebrow">Audit deliverables</span>
  <h1>This share link has expired.</h1>
  <p class="lede">
    The audit deliverables behind this link are no longer available with this URL.
    Get in touch with your Upriver contact for a fresh link.
  </p>
  <p class="footnote">
    Share links are time-limited so review materials don't stay open on the public web indefinitely.
  </p>
</MessageLayout>
