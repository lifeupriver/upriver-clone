---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import NewClientForm from '@/components/react/NewClientForm';
---

<DashboardLayout title="New client" section="clients">
  <div class="breadcrumb">
    <a href="/clients" class="bc-link">Clients</a>
    <span class="bc-sep">/</span>
    <span class="bc-current">New</span>
  </div>

  <div class="page-header">
    <span class="eyebrow">Onboarding</span>
    <h1>New client</h1>
    <p class="subtitle">
      Runs <code>upriver init &lt;url&gt; --slug &lt;slug&gt; --name &lt;name&gt;</code> in the
      background and streams the output below. On success you'll be redirected to the client
      detail page.
    </p>
  </div>

  <NewClientForm client:load />
</DashboardLayout>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    font-size: var(--fs-xs);
  }
  .bc-link {
    color: var(--text-muted);
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .bc-link:hover { color: var(--accent); }
  .bc-sep { color: var(--border); }
  .bc-current {
    color: var(--text-body);
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .page-header {
    margin-bottom: 1.75rem;
  }
  .page-header h1 { margin: 0.25rem 0 0.5rem; }
  .subtitle {
    color: var(--text-muted);
    font-size: var(--fs-sm);
    margin: 0;
    max-width: 60ch;
    line-height: 1.55;
  }
  .subtitle code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    color: var(--accent);
    background: var(--accent-05);
    padding: 0.05rem 0.3rem;
    border-radius: var(--radius-sm);
  }
</style>
