---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import ScoreStrip from '@/components/astro/ScoreStrip.astro';
import { FindingFilters } from '@/components/react/FindingFilters';
import { ScoreRadar } from '@/components/react/ScoreRadar';
import { readAuditPasses, readAuditSummary, readClientConfig, clientExists } from '@/lib/fs-reader';

const { slug } = Astro.params;

if (!slug || !(await clientExists(slug))) {
  return Astro.redirect('/clients');
}

const config = (await readClientConfig(slug))!;
const passes = await readAuditPasses(slug);
const summary = await readAuditSummary(slug);

if (passes.length === 0) {
  return Astro.redirect(`/clients/${slug}`);
}

const allFindings = passes.flatMap(p => p.findings);
const scores = Object.fromEntries(passes.map(p => [p.dimension, p.score]));
---

<DashboardLayout title={`${config.name} — Audit`} section="clients">
  <!-- Breadcrumb -->
  <div class="breadcrumb">
    <a href="/clients" class="bc-link">Clients</a>
    <span class="bc-sep">/</span>
    <a href={`/clients/${slug}`} class="bc-link">{config.name}</a>
    <span class="bc-sep">/</span>
    <span class="bc-current">Audit</span>
  </div>

  <div class="audit-header">
    <div>
      <span class="eyebrow">Audit Report</span>
      <h1>{config.name}</h1>
    </div>
    {summary && (
      <div class="header-score">
        <span class="score-label eyebrow">Overall</span>
        <span class="score-num big-score">{summary.overall}</span>
      </div>
    )}
  </div>

  <!-- Score strip + Radar -->
  <div class="top-section">
    <div class="score-strip-wrap">
      <ScoreStrip passes={passes} />
    </div>
    <div class="radar-wrap">
      <ScoreRadar client:load scores={scores} size={220} />
    </div>
  </div>

  <!-- Findings browser (interactive React island) -->
  <section class="findings-section">
    <h3>Findings ({allFindings.length})</h3>
    <FindingFilters client:load findings={allFindings} />
  </section>
</DashboardLayout>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    font-size: var(--fs-xs);
  }

  .bc-link {
    color: var(--text-muted);
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .bc-link:hover { color: var(--accent); }

  .bc-sep { color: var(--border); }

  .bc-current {
    color: var(--text-body);
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .audit-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .audit-header h1 { margin: 0.25rem 0 0; }

  .header-score {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.15rem;
    flex-shrink: 0;
  }

  .score-label { font-size: 0.7rem; }

  .big-score { font-size: 3rem; }

  .top-section {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    margin-bottom: 3rem;
  }

  .score-strip-wrap { flex: 1; min-width: 0; }

  .radar-wrap {
    flex-shrink: 0;
  }

  .findings-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .findings-section h3 {
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }
</style>
