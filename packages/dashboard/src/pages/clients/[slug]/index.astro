---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import PipelineStages from '@/components/react/PipelineStages';
import ScoreStrip from '@/components/astro/ScoreStrip.astro';
import FindingsTable from '@/components/astro/FindingsTable.astro';
import ArtifactCard from '@/components/astro/ArtifactCard.astro';
import {
  readClientConfig,
  readAuditPasses,
  readAuditSummary,
  readIntake,
  readFidelitySummary,
  getClientArtifacts,
  clientExists,
} from '@/lib/fs-reader';
import { detectStage, type PipelineStage } from '@/lib/pipeline';
import { getDataSource } from '@/lib/data-source';

const { slug } = Astro.params;

if (!slug || !(await clientExists(slug))) {
  const safeSlug = (slug ?? '').replace(/[<>&"']/g, '');
  return new Response(
    `<!doctype html>
<html lang="en"><head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Client not found — Upriver</title>
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<style>
  body { background: #faf7f2; color: #1f2937; font: 16px/1.55 system-ui, sans-serif; min-height: 100vh; margin: 0; display: grid; place-items: center; padding: 2rem 1.25rem; }
  .card { max-width: 28rem; background: #fff; border: 1px solid #e5e7eb; border-radius: 0.75rem; padding: 2.25rem 2rem 1.75rem; box-shadow: 0 12px 32px rgba(15, 23, 42, 0.06); }
  .eyebrow { display: block; margin-bottom: 0.75rem; font-size: 0.78rem; letter-spacing: 0.08em; text-transform: uppercase; color: #6b7280; }
  h1 { font-size: 1.875rem; letter-spacing: -0.02em; margin: 0 0 0.6rem; }
  p { margin: 0 0 1.5rem; }
  code { background: #f3f4f6; padding: 0.125rem 0.375rem; border-radius: 0.25rem; font-size: 0.9em; }
  .btn { display: inline-flex; align-items: center; padding: 0.75rem 1.25rem; font-weight: 500; font-size: 0.78rem; letter-spacing: 0.08em; text-transform: uppercase; color: #fff; background: #F1551A; border-radius: 0.375rem; text-decoration: none; }
</style>
</head><body>
<div class="card">
  <span class="eyebrow">404</span>
  <h1>Client not found.</h1>
  <p>No client matches <code>${safeSlug}</code>. It may have been removed or never existed.</p>
  <a class="btn" href="/clients">← Back to clients</a>
</div>
</body></html>`,
    {
      status: 404,
      headers: { 'content-type': 'text/html; charset=utf-8' },
    },
  );
}

const config = (await readClientConfig(slug))!;
const [passes, summary, stage, intake, fidelity, artifacts] = await Promise.all([
  readAuditPasses(slug),
  readAuditSummary(slug),
  detectStage(slug),
  readIntake(slug),
  readFidelitySummary(slug),
  getClientArtifacts(slug),
]);
const dataSource = getDataSource();

const allFindings = passes.flatMap(p => p.findings);
const p0Findings  = allFindings.filter(f => f.priority === 'p0');

const created = new Date(config.created_at).toLocaleDateString('en-US', {
  month: 'long', day: 'numeric', year: 'numeric'
});

function fmtShortDate(iso: string | null | undefined): string | null {
  if (!iso) return null;
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return null;
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

// Map the detected pipeline stage to a one-sentence "next step" recommendation
// + CTA target. Keep these terse — the full pipeline runner lives in the
// sidebar PipelineStages island; this is just the headline action.
interface NextStep {
  title: string;
  detail: string;
  ctaLabel: string;
  ctaHref: string;
}

// Detect-stage only ever returns this subset of pipeline stages, but
// `PipelineStage` is the full id union — so use a partial map and fall back
// to the `init` step for any unmapped value.
const nextStepByStage: Partial<Record<PipelineStage, NextStep>> = {
  init: {
    title: 'Discover the site',
    detail: 'Crawl pages and competitors to seed the audit.',
    ctaLabel: 'Run discover',
    ctaHref: `/clients/${slug}#pipeline`,
  },
  discover: {
    title: 'Scrape the live site',
    detail: 'Capture HTML and screenshots for every discovered page.',
    ctaLabel: 'Run scrape',
    ctaHref: `/clients/${slug}#pipeline`,
  },
  scrape: {
    title: 'Run the audit',
    detail: 'Score every dimension and generate findings.',
    ctaLabel: 'Run audit',
    ctaHref: `/clients/${slug}#pipeline`,
  },
  audit: {
    title: 'Synthesize the audit',
    detail: 'Compose findings into a single audit package the client can read.',
    ctaLabel: 'Run synthesize',
    ctaHref: `/clients/${slug}#pipeline`,
  },
  synthesize: {
    title: 'Generate the design brief',
    detail: 'Turn the audit into the operator design brief.',
    ctaLabel: 'Open audit',
    ctaHref: `/clients/${slug}/audit`,
  },
  'voice-extract': {
    title: 'Scaffold the new repo',
    detail: 'Brand voice is captured. Spin up the Astro repo for the rebuild.',
    ctaLabel: 'Run scaffold',
    ctaHref: `/clients/${slug}#pipeline`,
  },
  'design-brief': {
    title: 'Scaffold the new repo',
    detail: 'Brief is ready. Spin up the Astro repo for the rebuild.',
    ctaLabel: 'Open brief',
    ctaHref: `/clients/${slug}/design-brief`,
  },
  scaffold: {
    title: 'Clone the site',
    detail: 'Repo is scaffolded. Visual-clone every page into it.',
    ctaLabel: 'Run clone',
    ctaHref: `/clients/${slug}#pipeline`,
  },
  clone: {
    title: 'Plan the fixes',
    detail: 'Site is cloned. Generate the fixes plan before QA.',
    ctaLabel: 'Open site preview',
    ctaHref: `/clients/${slug}/site`,
  },
  'fixes-plan': {
    title: 'Run QA',
    detail: 'Fixes are planned. Re-audit the cloned site.',
    ctaLabel: 'Open fixes plan',
    ctaHref: `/clients/${slug}/fixes`,
  },
  qa: {
    title: 'Generate the launch checklist',
    detail: 'QA is logged. Compose the launch checklist and ship.',
    ctaLabel: 'Open QA report',
    ctaHref: `/clients/${slug}/qa`,
  },
  launch: {
    title: 'Ready to ship',
    detail: 'Launch checklist is ready. Walk it before going live.',
    ctaLabel: 'Open checklist',
    ctaHref: `/clients/${slug}/launch-checklist`,
  },
};

const nextStep: NextStep = nextStepByStage[stage] ?? nextStepByStage.init!;

// Artifact summaries — short strings shown under each card title.
const tierLabel: Record<string, string> = {
  polish: 'Polish',
  rebuild: 'Rebuild',
  'rebuild-plus-content': 'Rebuild + content',
};

const intakeSummary = artifacts.hasIntake && intake
  ? `${intake.scopeTier ? tierLabel[intake.scopeTier] ?? intake.scopeTier : 'Tier undecided'}${
      intake.submittedAt ? ` · submitted ${fmtShortDate(intake.submittedAt)}` : ''
    }`
  : undefined;

const interviewSummary = artifacts.hasInterviewResponses
  ? 'Responses captured'
  : artifacts.hasInterviewSpec
  ? 'Guide ready, awaiting client'
  : undefined;

const auditSummary = artifacts.hasAudit && summary
  ? `${summary.p0_count} P0 · ${summary.total_findings} findings · score ${summary.overall}`
  : undefined;

const fidelitySummary = artifacts.hasFidelity && fidelity
  ? `Overall fidelity ${fidelity.overall}`
  : undefined;
---

<DashboardLayout title={config.name} section="clients">
  <!-- Breadcrumb -->
  <div class="breadcrumb">
    <a href="/clients" class="bc-link">Clients</a>
    <span class="bc-sep">/</span>
    <span class="bc-current">{config.name}</span>
  </div>

  <!-- Client header -->
  <div class="client-header">
    <div>
      <span class="eyebrow">Client</span>
      <h1>{config.name}</h1>
      <a href={config.url} target="_blank" rel="noopener" class="client-url">
        {config.url}
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="vertical-align: middle; margin-left: 0.25rem;">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
          <polyline points="15 3 21 3 21 9"/>
          <line x1="10" y1="14" x2="21" y2="3"/>
        </svg>
      </a>
    </div>
    <div class="header-pills">
      {config.platform && config.platform !== 'unknown' && (
        <span class="pill pill-ghost">{config.platform}</span>
      )}
      {summary && (
        <span class="overall-score score-num">{summary.overall}</span>
      )}
    </div>
  </div>

  <!-- Next step strip -->
  <section class="next-step card">
    <div class="next-meta">
      <span class="eyebrow">Next step</span>
      <h3 class="next-title">{nextStep.title}</h3>
      <p class="next-detail">{nextStep.detail}</p>
    </div>
    <a href={nextStep.ctaHref} class="next-cta">{nextStep.ctaLabel} →</a>
  </section>

  <!-- Two-column layout -->
  <div class="client-body">
    <!-- Left: Meta + Pipeline -->
    <aside class="client-aside">
      <!-- Meta card -->
      <div class="card meta-card">
        <span class="eyebrow" style="margin-bottom: 0.75rem; display: block;">Details</span>
        <dl class="meta-list">
          <dt>Slug</dt>
          <dd class="mono">{config.slug}</dd>
          <dt>Created</dt>
          <dd>{created}</dd>
          {config.github_repo && (
            <>
              <dt>GitHub</dt>
              <dd>
                <a href={`https://github.com/${config.github_repo}`} target="_blank" rel="noopener" class="meta-link">
                  {config.github_repo}
                </a>
              </dd>
            </>
          )}
          {config.vercel_preview_url && (
            <>
              <dt>Preview</dt>
              <dd>
                <a href={config.vercel_preview_url} target="_blank" rel="noopener" class="meta-link">
                  Open preview
                </a>
              </dd>
            </>
          )}
        </dl>
      </div>

      <!-- Pipeline -->
      <div class="card pipeline-card" id="pipeline">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
          <span class="eyebrow">Pipeline</span>
          <span class="eyebrow" style="font-size: 0.62rem; color: var(--text-muted);">click Run to invoke</span>
        </div>
        <PipelineStages slug={slug} currentStage={stage} dataSource={dataSource} client:load />
      </div>
    </aside>

    <!-- Right: Workspace + Scores + Findings -->
    <div class="client-main">
      <!-- Workspace artifact grid -->
      <section class="section">
        <div class="section-header">
          <h3>Workspace</h3>
          <span class="mono section-hint">artifacts for this client</span>
        </div>

        <div class="artifact-group">
          <span class="eyebrow group-label">Inputs</span>
          <div class="artifact-grid">
            <ArtifactCard
              title="Intake"
              status={artifacts.hasIntake ? 'ready' : 'empty'}
              href={`/clients/${slug}/intake`}
              summary={intakeSummary}
            />
            <ArtifactCard
              title="Interview"
              status={artifacts.hasInterviewResponses ? 'ready' : artifacts.hasInterviewSpec ? 'stale' : 'empty'}
              href={`/clients/${slug}/interview`}
              summary={interviewSummary}
            />
          </div>
        </div>

        <div class="artifact-group">
          <span class="eyebrow group-label">Audit</span>
          <div class="artifact-grid">
            <ArtifactCard
              title="Audit Report"
              status={artifacts.hasAudit ? 'ready' : 'empty'}
              href={`/clients/${slug}/audit`}
              summary={auditSummary}
            />
            <ArtifactCard
              title="Clone Fidelity"
              status={artifacts.hasFidelity ? 'ready' : 'empty'}
              href={`/clients/${slug}/clone-fidelity`}
              summary={fidelitySummary}
            />
          </div>
        </div>

        <div class="artifact-group">
          <span class="eyebrow group-label">Outputs</span>
          <div class="artifact-grid">
            <ArtifactCard
              title="Brand Voice"
              status={artifacts.hasVoice ? 'ready' : 'empty'}
              href={`/clients/${slug}/voice`}
            />
            <ArtifactCard
              title="Design Brief"
              status={artifacts.hasBrief ? 'ready' : 'empty'}
              href={`/clients/${slug}/design-brief`}
            />
            <ArtifactCard
              title="Site Preview"
              status={artifacts.hasRepo ? 'ready' : 'empty'}
              href={`/clients/${slug}/site`}
              summary={artifacts.hasRepo ? 'Cloned repo available' : undefined}
            />
            <ArtifactCard
              title="Fixes Plan"
              status={artifacts.hasFixes ? 'ready' : 'empty'}
              href={`/clients/${slug}/fixes`}
            />
            <ArtifactCard
              title="QA Report"
              status={artifacts.hasQa ? 'ready' : 'empty'}
              href={`/clients/${slug}/qa`}
            />
            <ArtifactCard
              title="Launch Checklist"
              status={artifacts.hasLaunch ? 'ready' : 'empty'}
              href={`/clients/${slug}/launch-checklist`}
            />
          </div>
        </div>

        <div class="artifact-group">
          <span class="eyebrow group-label">Share</span>
          <div class="artifact-grid">
            <ArtifactCard
              title="Export Audit"
              status={artifacts.hasAudit ? 'ready' : 'empty'}
              href={`/deliverables/${slug}`}
              summary="Client-facing audit report"
              ctaLabel="Open export →"
            />
            <ArtifactCard
              title="Export Brief"
              status={artifacts.hasBrief ? 'ready' : 'empty'}
              href={`/deliverables/${slug}/design-brief`}
              summary="Client-facing design brief"
              ctaLabel="Open export →"
            />
            <ArtifactCard
              title="Share Links"
              status="ready"
              href={`/clients/${slug}/share`}
              summary="Generate read-only share tokens"
              ctaLabel="Manage →"
            />
          </div>
        </div>
      </section>

      {passes.length > 0 ? (
        <>
          <section class="section">
            <div class="section-header">
              <h3>Audit Scores</h3>
              {summary && (
                <span class="mono" style="color: var(--text-muted); font-size: var(--fs-sm);">
                  Overall: <span class="score-num" style="font-size: 1.25rem;">{summary.overall}</span>
                </span>
              )}
            </div>
            <ScoreStrip passes={passes} slug={slug} />
          </section>

          {p0Findings.length > 0 && (
            <section class="section">
              <div class="section-header">
                <h3>Critical Findings</h3>
                <a href={`/clients/${slug}/audit`} class="see-all">See all →</a>
              </div>
              <FindingsTable findings={p0Findings} limit={5} />
            </section>
          )}
        </>
      ) : (
        <div class="no-audit">
          <p>No audit data yet. Run <code>upriver audit {slug}</code> to generate scores.</p>
        </div>
      )}
    </div>
  </div>
</DashboardLayout>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    font-size: var(--fs-xs);
  }

  .bc-link {
    color: var(--text-muted);
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .bc-link:hover { color: var(--accent); }

  .bc-sep { color: var(--border); }

  .bc-current {
    color: var(--text-body);
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .client-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .client-header h1 {
    margin: 0.25rem 0 0.375rem;
  }

  .client-url {
    color: var(--accent);
    font-size: var(--fs-sm);
    font-family: var(--font-mono);
    transition: color var(--dur-fast) var(--ease-out);
  }

  .client-url:hover { color: var(--accent-hover); }

  .header-pills {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .overall-score { font-size: 2.5rem; }

  .next-step {
    margin-bottom: 2rem;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    border-color: var(--accent-20);
    background: linear-gradient(180deg, var(--accent-05), var(--bg-surface));
  }

  .next-meta { display: flex; flex-direction: column; gap: 0.25rem; }
  .next-title { margin: 0.15rem 0 0.1rem; font-size: 1.15rem; }
  .next-detail { color: var(--text-muted); font-size: var(--fs-sm); margin: 0; }

  .next-cta {
    flex-shrink: 0;
    padding: 0.65rem 1.1rem;
    background: var(--accent);
    color: #fff;
    border-radius: var(--radius-sm);
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    box-shadow: var(--shadow-btn-primary);
    transition: background var(--dur-fast) var(--ease-out);
  }
  .next-cta:hover { background: var(--accent-hover); }

  .client-body {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 2rem;
    align-items: start;
  }

  .client-aside {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .meta-card, .pipeline-card {
    padding: 1.25rem;
  }

  .meta-list {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.25rem 0.75rem;
    margin: 0;
  }

  .meta-list dt {
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    align-self: center;
  }

  .meta-list dd {
    margin: 0;
    color: var(--text-body);
    font-size: var(--fs-sm);
    word-break: break-all;
    align-self: center;
  }

  .meta-link {
    color: var(--accent);
    font-size: var(--fs-sm);
    transition: color var(--dur-fast) var(--ease-out);
  }

  .meta-link:hover { color: var(--accent-hover); }

  .client-main {
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
  }

  .section {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .section-hint { color: var(--text-muted); font-size: var(--fs-xs); }

  .artifact-group {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin-top: 0.5rem;
  }

  .group-label { font-size: 0.7rem; }

  .artifact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.75rem;
  }

  .see-all {
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    transition: color var(--dur-fast) var(--ease-out);
  }

  .see-all:hover { color: var(--accent-hover); }

  .no-audit {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    text-align: center;
    color: var(--text-muted);
  }

  .no-audit code {
    font-family: var(--font-mono);
    color: var(--accent);
  }
</style>
