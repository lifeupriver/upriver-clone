---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import PipelineStages from '@/components/react/PipelineStages';
import ScoreStrip from '@/components/astro/ScoreStrip.astro';
import FindingsTable from '@/components/astro/FindingsTable.astro';
import ArtifactCard, { type ArtifactStatus } from '@/components/astro/ArtifactCard.astro';
import {
  readClientConfig,
  readAuditPasses,
  readAuditSummary,
  readIntake,
  readFidelitySummary,
  getClientArtifacts,
  clientExists,
} from '@/lib/fs-reader';
import { detectStage, type PipelineStage } from '@/lib/pipeline';
import { PHASES, phaseOfStage, phaseIndex, type PhaseKey } from '@/lib/phases';
import { readAuditPackage } from '@/lib/report-reader';
import { getDataSource } from '@/lib/data-source';

const { slug } = Astro.params;

if (!slug || !(await clientExists(slug))) {
  const safeSlug = (slug ?? '').replace(/[<>&"']/g, '');
  return new Response(
    `<!doctype html>
<html lang="en"><head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Client not found — Upriver</title>
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<style>
  body { background: #faf7f2; color: #1f2937; font: 16px/1.55 system-ui, sans-serif; min-height: 100vh; margin: 0; display: grid; place-items: center; padding: 2rem 1.25rem; }
  .card { max-width: 28rem; background: #fff; border: 1px solid #e5e7eb; border-radius: 0.75rem; padding: 2.25rem 2rem 1.75rem; box-shadow: 0 12px 32px rgba(15, 23, 42, 0.06); }
  .eyebrow { display: block; margin-bottom: 0.75rem; font-size: 0.78rem; letter-spacing: 0.08em; text-transform: uppercase; color: #6b7280; }
  h1 { font-size: 1.875rem; letter-spacing: -0.02em; margin: 0 0 0.6rem; }
  p { margin: 0 0 1.5rem; }
  code { background: #f3f4f6; padding: 0.125rem 0.375rem; border-radius: 0.25rem; font-size: 0.9em; }
  .btn { display: inline-flex; align-items: center; padding: 0.75rem 1.25rem; font-weight: 500; font-size: 0.78rem; letter-spacing: 0.08em; text-transform: uppercase; color: #fff; background: #F1551A; border-radius: 0.375rem; text-decoration: none; }
</style>
</head><body>
<div class="card">
  <span class="eyebrow">404</span>
  <h1>Client not found.</h1>
  <p>No client matches <code>${safeSlug}</code>. It may have been removed or never existed.</p>
  <a class="btn" href="/clients">← Back to clients</a>
</div>
</body></html>`,
    {
      status: 404,
      headers: { 'content-type': 'text/html; charset=utf-8' },
    },
  );
}

const config = (await readClientConfig(slug))!;
const [passes, summary, stage, intake, fidelity, artifacts, auditPackage] = await Promise.all([
  readAuditPasses(slug),
  readAuditSummary(slug),
  detectStage(slug),
  readIntake(slug),
  readFidelitySummary(slug),
  getClientArtifacts(slug),
  readAuditPackage(slug),
]);
const dataSource = getDataSource();

const allFindings = passes.flatMap(p => p.findings);
const p0Findings  = allFindings.filter(f => f.priority === 'p0');

// `summary.json` (audit stage) carries the overall score, but it's back-filled
// during synthesize into `audit-package.json` — the same source the client
// report reads. Prefer summary, fall back to the package, so the overview
// shows the real score (e.g. 72) instead of "—" next to populated tiles.
const overallScore = summary?.overall ?? auditPackage?.meta?.overallScore ?? null;

const created = new Date(config.created_at).toLocaleDateString('en-US', {
  month: 'long', day: 'numeric', year: 'numeric'
});

function fmtShortDate(iso: string | null | undefined): string | null {
  if (!iso) return null;
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return null;
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

// Map the detected pipeline stage to a one-sentence "next step" recommendation
// + CTA target. Keep these terse — the full pipeline runner lives in the
// collapsible runner below; this is just the single headline action.
interface NextStep {
  title: string;
  detail: string;
  ctaLabel: string;
  ctaHref: string;
}

// Detect-stage only ever returns this subset of pipeline stages, but
// `PipelineStage` is the full id union — so use a partial map and fall back
// to the `init` step for any unmapped value.
const nextStepByStage: Partial<Record<PipelineStage, NextStep>> = {
  init: {
    title: 'Discover the site',
    detail: 'Crawl pages and competitors to seed the audit.',
    ctaLabel: 'Run discover',
    ctaHref: `/clients/${slug}#pipeline`,
  },
  discover: {
    title: 'Scrape the live site',
    detail: 'Capture HTML and screenshots for every discovered page.',
    ctaLabel: 'Run scrape',
    ctaHref: `/clients/${slug}#pipeline`,
  },
  scrape: {
    title: 'Run the audit',
    detail: 'Score every dimension and generate findings.',
    ctaLabel: 'Run audit',
    ctaHref: `/clients/${slug}#pipeline`,
  },
  audit: {
    title: 'Synthesize the audit',
    detail: 'Compose findings into a single audit package the client can read.',
    ctaLabel: 'Run synthesize',
    ctaHref: `/clients/${slug}#pipeline`,
  },
  synthesize: {
    title: 'Generate the design brief',
    detail: 'Turn the audit into the operator design brief.',
    ctaLabel: 'Open audit',
    ctaHref: `/clients/${slug}/audit`,
  },
  'voice-extract': {
    title: 'Scaffold the new repo',
    detail: 'Brand voice is captured. Spin up the Astro repo for the rebuild.',
    ctaLabel: 'Run scaffold',
    ctaHref: `/clients/${slug}#pipeline`,
  },
  'design-brief': {
    title: 'Scaffold the new repo',
    detail: 'Brief is ready. Spin up the Astro repo for the rebuild.',
    ctaLabel: 'Open brief',
    ctaHref: `/clients/${slug}/design-brief`,
  },
  scaffold: {
    title: 'Clone the site',
    detail: 'Repo is scaffolded. Visual-clone every page into it.',
    ctaLabel: 'Run clone',
    ctaHref: `/clients/${slug}#pipeline`,
  },
  clone: {
    title: 'Plan the fixes',
    detail: 'Site is cloned. Generate the fixes plan before QA.',
    ctaLabel: 'Open site preview',
    ctaHref: `/clients/${slug}/site`,
  },
  'fixes-plan': {
    title: 'Run QA',
    detail: 'Fixes are planned. Re-audit the cloned site.',
    ctaLabel: 'Open fixes plan',
    ctaHref: `/clients/${slug}/fixes`,
  },
  qa: {
    title: 'Generate the launch checklist',
    detail: 'QA is logged. Compose the launch checklist and ship.',
    ctaLabel: 'Open QA report',
    ctaHref: `/clients/${slug}/qa`,
  },
  launch: {
    title: 'Ready to ship',
    detail: 'Launch checklist is ready. Walk it before going live.',
    ctaLabel: 'Open checklist',
    ctaHref: `/clients/${slug}/launch-checklist`,
  },
};

const nextStep: NextStep = nextStepByStage[stage] ?? nextStepByStage.init!;

// Artifact summaries — short strings shown under each row title.
const tierLabel: Record<string, string> = {
  polish: 'Polish',
  rebuild: 'Rebuild',
  'rebuild-plus-content': 'Rebuild + content',
};

const intakeSummary = artifacts.hasIntake && intake
  ? `${intake.scopeTier ? tierLabel[intake.scopeTier] ?? intake.scopeTier : 'Tier undecided'}${
      intake.submittedAt ? ` · submitted ${fmtShortDate(intake.submittedAt)}` : ''
    }`
  : undefined;

const interviewSummary = artifacts.hasInterviewResponses
  ? 'Responses captured'
  : artifacts.hasInterviewSpec
  ? 'Guide ready, awaiting client'
  : undefined;

// Derive counts from the actual findings (reliable) rather than `summary`,
// whose `p0_count`/`overall` fields can be absent in older summary.json files —
// that previously rendered the literal strings "undefined" / "score undefined".
const auditSummary = artifacts.hasAudit
  ? `${p0Findings.length} P0 · ${allFindings.length} findings${
      overallScore != null ? ` · score ${overallScore}` : ''
    }`
  : undefined;

const fidelitySummary = artifacts.hasFidelity && fidelity
  ? `Overall fidelity ${fidelity.overall}`
  : undefined;

// ── Phase spine ──────────────────────────────────────────────────────────
// The four phases each own a set of deliverables. This single structure
// replaces the old flat 25-row Run list + 13-card workspace grid: status,
// artifacts, and the run-action now live together under one spine.
interface ArtifactRow {
  title: string;
  href: string;
  status: ArtifactStatus;
  summary?: string;
  ctaLabel?: string;
}

const artifactsByPhase: Record<PhaseKey, ArtifactRow[]> = {
  intake: [
    { title: 'Intake', href: `/clients/${slug}/intake`, status: artifacts.hasIntake ? 'ready' : 'empty', summary: intakeSummary },
    { title: 'Interview', href: `/clients/${slug}/interview`, status: artifacts.hasInterviewResponses ? 'ready' : artifacts.hasInterviewSpec ? 'stale' : 'empty', summary: interviewSummary },
  ],
  audit: [
    { title: 'Audit Report', href: `/clients/${slug}/audit`, status: artifacts.hasAudit ? 'ready' : 'empty', summary: auditSummary },
    { title: 'Brand Voice', href: `/clients/${slug}/voice`, status: artifacts.hasVoice ? 'ready' : 'empty' },
  ],
  build: [
    { title: 'Design Brief', href: `/clients/${slug}/design-brief`, status: artifacts.hasBrief ? 'ready' : 'empty' },
    { title: 'Site Preview', href: `/clients/${slug}/site`, status: artifacts.hasRepo ? 'ready' : 'empty', summary: artifacts.hasRepo ? 'Cloned repo available' : undefined },
    { title: 'Clone Fidelity', href: `/clients/${slug}/clone-fidelity`, status: artifacts.hasFidelity ? 'ready' : 'empty', summary: fidelitySummary },
    { title: 'Fixes Plan', href: `/clients/${slug}/fixes`, status: artifacts.hasFixes ? 'ready' : 'empty' },
    { title: 'QA Report', href: `/clients/${slug}/qa`, status: artifacts.hasQa ? 'ready' : 'empty' },
  ],
  launch: [
    { title: 'Launch Checklist', href: `/clients/${slug}/launch-checklist`, status: artifacts.hasLaunch ? 'ready' : 'empty' },
  ],
};

const currentPhaseKey = phaseOfStage(stage);
const currentIdx = phaseIndex(currentPhaseKey);

type PhaseStatus = 'done' | 'active' | 'todo';
interface PhaseView {
  key: PhaseKey;
  label: string;
  blurb: string;
  rows: ArtifactRow[];
  readyCount: number;
  total: number;
  status: PhaseStatus;
  chip: string;
  isCurrent: boolean;
}

const phaseViews: PhaseView[] = PHASES.map((p) => {
  const rows = artifactsByPhase[p.key];
  const readyCount = rows.filter((r) => r.status === 'ready').length;
  const total = rows.length;
  const isCurrent = p.key === currentPhaseKey;
  const allReady = total > 0 && readyCount === total;
  let status: PhaseStatus;
  if (allReady) status = 'done';
  else if (isCurrent) status = 'active';
  else status = 'todo';
  let chip: string;
  if (allReady) chip = 'Done';
  else if (readyCount > 0) chip = `${readyCount}/${total} ready`;
  else if (isCurrent) chip = 'Up next';
  else chip = 'Not started';
  return { key: p.key, label: p.label, blurb: p.blurb, rows, readyCount, total, status, chip, isCurrent };
});

// Status-summary stat cards (coverage-page pattern).
const lastStarted = [...phaseViews].reverse().find((v) => v.readyCount > 0);
const phaseStat = lastStarted ? lastStarted.label : 'Not started';
const totalReady = phaseViews.reduce((n, v) => n + v.readyCount, 0);
const totalArtifacts = phaseViews.reduce((n, v) => n + v.total, 0);
const scoreStat = overallScore != null ? String(overallScore) : '—';
const criticalStat = passes.length > 0 ? String(p0Findings.length) : '—';
const runnableStageCount = PHASES.reduce((n, p) => n + p.stageIds.filter((id) => id !== 'init' && id !== 'discover' && id !== 'launch').length, 0);
---

<DashboardLayout title={config.name} section="clients">
  <div class="overview">
    <!-- Breadcrumb -->
    <div class="breadcrumb">
      <a href="/clients" class="bc-link">Clients</a>
      <span class="bc-sep">/</span>
      <span class="bc-current">{config.name}</span>
    </div>

    <!-- Client header -->
    <header class="client-header reveal">
      <div class="ch-id">
        <span class="eyebrow">Client</span>
        <h1>{config.name}</h1>
        <a href={config.url} target="_blank" rel="noopener" class="client-url">
          {config.url}
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="vertical-align: middle; margin-left: 0.25rem;">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            <polyline points="15 3 21 3 21 9"/>
            <line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        </a>
      </div>
      {config.platform && config.platform !== 'unknown' && (
        <span class="pill pill-ghost">{config.platform}</span>
      )}
    </header>

    <!-- Status summary -->
    <section class="stats reveal" aria-label="Status summary">
      <div class="stat card"><span class="num">{phaseStat}</span><span class="lbl">phase</span></div>
      <div class="stat card"><span class="num score">{scoreStat}</span><span class="lbl">audit score</span></div>
      <div class="stat card"><span class="num">{criticalStat}</span><span class="lbl">critical · P0</span></div>
      <div class="stat card"><span class="num">{totalReady}<span class="den">/{totalArtifacts}</span></span><span class="lbl">deliverables</span></div>
    </section>

    <!-- Hero: the single next action -->
    <section class="next-step card reveal">
      <div class="next-meta">
        <span class="eyebrow">Next step</span>
        <h2 class="next-title">{nextStep.title}</h2>
        <p class="next-detail">{nextStep.detail}</p>
      </div>
      <a href={nextStep.ctaHref} class="next-cta">{nextStep.ctaLabel} →</a>
    </section>

    <!-- Phase spine -->
    <section class="spine reveal" aria-label="Project phases">
      {phaseViews.map((p, i) => (
        <article class:list={['phase', `is-${p.status}`, { current: p.isCurrent }]}>
          <div class="phase-head">
            <span class="phase-index" aria-hidden="true">{i + 1}</span>
            <div class="phase-title">
              <h3>{p.label}</h3>
              <p class="phase-blurb">{p.blurb}</p>
            </div>
            <span class:list={['phase-chip', `chip-${p.status}`]}>{p.chip}</span>
          </div>
          <div class="phase-rows">
            {p.rows.map((r) => (
              <ArtifactCard title={r.title} status={r.status} href={r.href} summary={r.summary} ctaLabel={r.ctaLabel} />
            ))}
          </div>
        </article>
      ))}
    </section>

    <!-- Manual stage runner — progressive disclosure -->
    <details class="runner card" id="pipeline">
      <summary>
        <span class="runner-titles">
          <span class="runner-title">Run a pipeline stage</span>
          <span class="runner-hint">Advanced — invoke any of {runnableStageCount} stages by hand</span>
        </span>
        <span class="runner-caret" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </span>
      </summary>
      <div class="runner-body">
        <PipelineStages slug={slug} currentStage={stage} dataSource={dataSource} client:load />
      </div>
    </details>

    <!-- Audit detail (only when there is audit data) -->
    {passes.length > 0 && (
      <section class="section reveal">
        <div class="section-header">
          <h3>Audit scores</h3>
          {summary && (
            <span class="mono section-hint">
              Overall <span class="score-num" style="font-size: 1.25rem;">{summary.overall}</span>
            </span>
          )}
        </div>
        <ScoreStrip passes={passes} slug={slug} />
      </section>
    )}

    {p0Findings.length > 0 && (
      <section class="section reveal">
        <div class="section-header">
          <h3>Critical findings</h3>
          <a href={`/clients/${slug}/audit`} class="see-all">See all →</a>
        </div>
        <FindingsTable findings={p0Findings} limit={5} />
      </section>
    )}

    <!-- Footer: meta + client-facing share links -->
    <footer class="overview-footer reveal">
      <div class="meta-strip">
        <span class="meta-item"><span class="eyebrow">Slug</span><span class="mono">{config.slug}</span></span>
        <span class="meta-item"><span class="eyebrow">Created</span><span>{created}</span></span>
        {config.github_repo && (
          <span class="meta-item">
            <span class="eyebrow">GitHub</span>
            <a href={`https://github.com/${config.github_repo}`} target="_blank" rel="noopener" class="meta-link">{config.github_repo}</a>
          </span>
        )}
        {config.vercel_preview_url && (
          <span class="meta-item">
            <span class="eyebrow">Preview</span>
            <a href={config.vercel_preview_url} target="_blank" rel="noopener" class="meta-link">Open preview</a>
          </span>
        )}
      </div>
      <div class="share-strip">
        <span class="eyebrow">Share with client</span>
        <a href={`/deliverables/${slug}`} class="share-link">Audit report →</a>
        <a href={`/deliverables/${slug}/design-brief`} class="share-link">Design brief →</a>
        <a href={`/clients/${slug}/share`} class="share-link">Share links →</a>
      </div>
    </footer>

    <!-- Open the runner when arriving via a "Run …" CTA (#pipeline). -->
    <script is:inline>
      (function () {
        function openPipeline() {
          if (location.hash === '#pipeline') {
            var r = document.getElementById('pipeline');
            if (r) r.open = true;
          }
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', openPipeline);
        } else {
          openPipeline();
        }
        window.addEventListener('hashchange', openPipeline);
      })();
    </script>
  </div>
</DashboardLayout>

<style>
  .overview {
    max-width: 940px;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  /* ── Breadcrumb ──────────────────────────────────────────────────── */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--fs-xs);
    margin-bottom: -0.25rem;
  }
  .bc-link, .bc-current {
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .bc-link { color: var(--text-muted); transition: color var(--dur-fast) var(--ease-out); }
  .bc-link:hover { color: var(--accent); }
  .bc-sep { color: var(--border); }
  .bc-current { color: var(--text-body); }

  /* ── Header ──────────────────────────────────────────────────────── */
  .client-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }
  .client-header h1 { margin: 0.3rem 0 0.4rem; }
  .client-url {
    color: var(--accent);
    font-size: var(--fs-sm);
    font-family: var(--font-mono);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .client-url:hover { color: var(--accent-hover); }

  /* ── Status summary ──────────────────────────────────────────────── */
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1rem 1.15rem;
  }
  .stat .num {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    line-height: 1.05;
    color: var(--text-heading);
    letter-spacing: -0.01em;
  }
  .stat .num.score { font-family: var(--font-mono); color: var(--accent); }
  .stat .num .den { color: var(--text-muted); font-size: 1.1rem; }
  .stat .lbl {
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* ── Hero next step ──────────────────────────────────────────────── */
  .next-step {
    padding: 1.35rem 1.6rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    border-color: var(--accent-30);
    background: linear-gradient(135deg, var(--accent-10), var(--bg-surface) 65%);
  }
  .next-step:hover { transform: none; border-color: var(--accent-30); box-shadow: none; }
  .next-meta { display: flex; flex-direction: column; gap: 0.2rem; }
  .next-title { margin: 0.15rem 0 0.1rem; font-size: 1.35rem; color: var(--text-heading); }
  .next-detail { color: var(--text-body); font-size: var(--fs-sm); margin: 0; }
  .next-cta {
    flex-shrink: 0;
    padding: 0.75rem 1.3rem;
    background: var(--accent);
    color: #fff;
    border-radius: var(--radius-md);
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    box-shadow: var(--shadow-btn-primary);
    transition: background var(--dur-fast) var(--ease-out), transform var(--dur-fast) var(--ease-out);
  }
  .next-cta:hover { background: var(--accent-hover); transform: translateY(-1px); }

  /* ── Phase spine ─────────────────────────────────────────────────── */
  .spine { display: flex; flex-direction: column; gap: 0.75rem; }

  .phase {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.1rem 1.25rem 0.75rem;
  }
  .phase.is-done { border-left-color: var(--success); }
  .phase.is-active.current {
    border-left-color: var(--accent);
    background: linear-gradient(180deg, var(--accent-05), var(--bg-surface) 40%);
  }

  .phase-head {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.85rem;
    padding-bottom: 0.5rem;
  }
  .phase-index {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
  }
  .phase.is-done .phase-index { color: var(--success); border-color: var(--success); }
  .phase.is-active.current .phase-index { color: var(--accent); border-color: var(--accent-30); }
  .phase-title h3 { font-size: 1.15rem; margin: 0; }
  .phase-blurb { margin: 0.1rem 0 0; color: var(--text-muted); font-size: var(--fs-sm); }

  .phase-chip {
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--border);
    white-space: nowrap;
  }
  .chip-done { color: var(--success); border-color: rgba(74,155,110,0.4); background: rgba(74,155,110,0.1); }
