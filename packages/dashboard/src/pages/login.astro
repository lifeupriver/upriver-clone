---
import '../styles/global.css';
import { createSupabaseServerClient, getSessionUser, isOperator } from '@/lib/auth';

// If already signed in as operator, send straight to /clients.
const existing = await getSessionUser(Astro.request, Astro.cookies);
if (isOperator(existing)) {
  return Astro.redirect('/clients');
}

let error: string | null = null;
let sent = false;
let submittedEmail = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const email = String(form.get('email') ?? '').trim().toLowerCase();
  submittedEmail = email;
  if (!email || !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) {
    error = 'Enter a valid email address.';
  } else {
    const supa = createSupabaseServerClient(Astro.request, Astro.cookies);
    const origin = new URL(Astro.request.url).origin;
    const { error: otpError } = await supa.auth.signInWithOtp({
      email,
      options: { emailRedirectTo: `${origin}/auth/callback` },
    });
    if (otpError) {
      error = otpError.message;
    } else {
      sent = true;
    }
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sign in — Upriver</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <main class="auth-shell">
      <div class="auth-card">
        <a href="/" class="brand" aria-label="Upriver">
          <svg width="28" height="26" viewBox="0 0 40 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M20 2 L38 34 H22 L20 28 L18 34 H2 Z" stroke="#F1551A" stroke-width="2.5" stroke-linejoin="round" fill="none"/>
            <path d="M12 34 L20 14 L28 34" stroke="#F1551A" stroke-width="2.5" stroke-linejoin="round" fill="none"/>
          </svg>
          <span class="brand-name">Upriver</span>
        </a>

        <span class="eyebrow">Operator sign-in</span>

        {sent ? (
          <>
            <h1>Check your inbox</h1>
            <p class="lede">
              A magic link is on its way to <strong>{submittedEmail}</strong>. Click it to finish signing in — it expires in an hour.
            </p>
            <a href="/login" class="btn-secondary">Use a different email</a>
          </>
        ) : (
          <>
            <h1>Welcome back.</h1>
            <p class="lede">
              Sign in to run the pipeline, review deliverables, and ship audits.
            </p>

            <form method="post" novalidate>
              <label for="email">Email</label>
              <input
                id="email"
                name="email"
                type="email"
                inputmode="email"
                autocomplete="email"
                required
                autofocus
                placeholder="you@example.com"
                value={submittedEmail}
              />
              {error && <p class="error" role="alert">{error}</p>}
              <button type="submit" class="btn-primary">Send magic link</button>
            </form>
          </>
        )}

        <p class="footnote">
          No password — we email a one-click sign-in link. Access is limited to allowlisted operator addresses.
        </p>
      </div>
    </main>

    <style>
      html, body {
        background: var(--bg-primary);
        min-height: 100vh;
      }

      .auth-shell {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 2rem 1.25rem;
        position: relative;
        overflow: hidden;
      }

      /* Subtle warm glow behind the card. */
      .auth-shell::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
          radial-gradient(ellipse 60% 50% at 50% 35%, var(--accent-glow), transparent 70%),
          radial-gradient(ellipse 80% 60% at 50% 110%, rgba(241, 85, 26, 0.06), transparent 70%);
        pointer-events: none;
        z-index: 0;
      }

      .auth-card {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: 28rem;
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 2.25rem 2rem 1.75rem;
        box-shadow: var(--shadow-card-soft);
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        margin-bottom: 1.5rem;
        text-decoration: none;
      }

      .brand-name {
        font-family: var(--font-heading);
        font-weight: 500;
        font-size: 1.1rem;
        letter-spacing: 0.01em;
        color: var(--text-heading);
      }

      .eyebrow {
        display: block;
        margin-bottom: 0.75rem;
      }

      h1 {
        font-size: 1.875rem;
        letter-spacing: -0.02em;
        margin-bottom: 0.6rem;
      }

      .lede {
        color: var(--text-body);
        font-size: var(--fs-body);
        line-height: 1.55;
        margin-bottom: 1.5rem;
        max-width: 24rem;
      }

      form { display: flex; flex-direction: column; }

      label {
        font-family: var(--font-heading);
        font-weight: 500;
        font-size: var(--fs-xs);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 0.5rem;
      }

      input[type='email'] {
        width: 100%;
        padding: 0.7rem 0.85rem;
        font-family: var(--font-body);
        font-size: 1rem;
        color: var(--text-heading);
        background: var(--bg-primary);
        border: 1px solid var(--border-input);
        border-radius: var(--radius-md);
        transition: border-color var(--dur-fast, 150ms) var(--ease-out),
                    box-shadow var(--dur-fast, 150ms) var(--ease-out);
      }

      input[type='email']::placeholder { color: var(--text-muted); opacity: 0.6; }

      input[type='email']:focus {
        outline: none;
        border-color: var(--accent);
        box-shadow: 0 0 0 3px var(--accent-20);
      }

      .error {
        margin-top: 0.6rem;
        color: var(--accent);
        font-size: var(--fs-sm);
      }

      .btn-primary {
        margin-top: 1.1rem;
        padding: 0.75rem 1.25rem;
        font-family: var(--font-heading);
        font-weight: 500;
        font-size: var(--fs-xs);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #fff;
        background: var(--accent);
        border: 0;
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-btn-primary);
        cursor: pointer;
        transform: translateY(0);
        transition: background var(--dur-fast, 150ms) var(--ease-out),
                    transform var(--dur-fast, 150ms) var(--ease-out),
                    box-shadow var(--dur-fast, 150ms) var(--ease-out);
      }
      .btn-primary:hover {
        background: var(--accent-hover);
        box-shadow: var(--shadow-btn-primary-hover);
      }
      .btn-primary:active {
        transform: translateY(2px);
        box-shadow: 0 2px 0 var(--accent-shadow), 0 6px 10px rgba(241, 85, 26, 0.25);
      }
      .btn-primary:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
      }

      .btn-secondary {
        display: inline-flex;
        align-items: center;
        margin-top: 1.25rem;
        padding: 0.55rem 1rem;
        font-family: var(--font-heading);
        font-weight: 500;
        font-size: var(--fs-xs);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-heading);
        background: transparent;
        border: 1px solid var(--border-input);
        border-radius: var(--radius-md);
        text-decoration: none;
        transition: border-color var(--dur-fast, 150ms) var(--ease-out),
                    color var(--dur-fast, 150ms) var(--ease-out);
      }
      .btn-secondary:hover {
        border-color: var(--accent);
        color: var(--accent);
      }

      .footnote {
        margin-top: 1.75rem;
        padding-top: 1.25rem;
        border-top: 1px solid var(--border);
        color: var(--text-muted);
        font-size: var(--fs-sm);
        line-height: 1.55;
      }

      @media (max-width: 30rem) {
        .auth-card { padding: 1.75rem 1.4rem 1.4rem; }
        h1 { font-size: 1.625rem; }
      }
    </style>
  </body>
</html>
