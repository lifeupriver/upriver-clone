---
import { createSupabaseServerClient, getSessionUser, isOperator } from '@/lib/auth';

// If already signed in as operator, send straight to /clients.
const existing = await getSessionUser(Astro.request, Astro.cookies);
if (isOperator(existing)) {
  return Astro.redirect('/clients');
}

let error: string | null = null;
let sent = false;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const email = String(form.get('email') ?? '').trim().toLowerCase();
  if (!email || !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) {
    error = 'Enter a valid email address.';
  } else {
    const supa = createSupabaseServerClient(Astro.request, Astro.cookies);
    const origin = new URL(Astro.request.url).origin;
    const { error: otpError } = await supa.auth.signInWithOtp({
      email,
      options: { emailRedirectTo: `${origin}/auth/callback` },
    });
    if (otpError) {
      error = otpError.message;
    } else {
      sent = true;
    }
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Sign in — Upriver</title>
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <style>
      :root { color-scheme: light dark; }
      body { font: 16px/1.5 system-ui, sans-serif; max-width: 26rem; margin: 6rem auto; padding: 0 1rem; color: #1f2937; }
      h1 { font-size: 1.4rem; margin: 0 0 1.2rem; }
      label { display: block; font-size: 0.85rem; margin-bottom: 0.4rem; color: #374151; }
      input[type=email] { width: 100%; padding: 0.55rem 0.7rem; font-size: 1rem; border: 1px solid #d1d5db; border-radius: 0.375rem; }
      button { margin-top: 0.9rem; padding: 0.55rem 1.1rem; font-size: 0.95rem; background: #111827; color: #fff; border: 0; border-radius: 0.375rem; cursor: pointer; }
      .error { color: #b91c1c; font-size: 0.85rem; margin-top: 0.6rem; }
      .sent { color: #15803d; font-size: 0.95rem; margin-top: 0.6rem; }
      .muted { color: #6b7280; font-size: 0.8rem; margin-top: 1.5rem; }
    </style>
  </head>
  <body>
    <h1>Sign in to Upriver</h1>

    {sent ? (
      <p class="sent">Check your email — we sent a magic link. Click it to finish signing in.</p>
    ) : (
      <form method="post">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" autocomplete="email" required autofocus />
        {error && <p class="error">{error}</p>}
        <button type="submit">Send magic link</button>
      </form>
    )}

    <p class="muted">Operator access is gated on a single seed email. If your address isn't in the allowlist, the link will sign you in as a regular user but operator-only routes will still return 403.</p>
  </body>
</html>
