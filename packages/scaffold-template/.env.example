# Supabase (public — Astro only exposes PUBLIC_-prefixed vars to the browser)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server-only, used by SSR admin routes — never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Canonical site origin — drives the sitemap, canonical links, and OG URLs
PUBLIC_SITE_URL=https://example.com

# GitHub (used by the change-request form to open issues)
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-org
GITHUB_REPO=your-client-repo

# Client metadata (overwritten per-client by `upriver scaffold`)
CLIENT_SLUG=example
PRODUCTION_URL=https://example.com
