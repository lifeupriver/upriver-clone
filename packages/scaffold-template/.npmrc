# Treat the scaffolded client repo as a standalone project, not part of the
# upriver workspace. Without this, `pnpm install` walks up to the upriver
# pnpm-workspace.yaml (which only includes packages/*) and silently does
# nothing for clients/<slug>/repo/. The headless clone and fixes-apply agents
# rely on `pnpm install` and `pnpm build` running from inside this dir.
ignore-workspace=true
