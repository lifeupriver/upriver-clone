---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const user = Astro.locals.user as { email?: string } | null;

const navItems = [
  { href: '/admin/dashboard', label: 'Dashboard' },
  { href: '/admin/inquiries', label: 'Inquiries' },
  { href: '/admin/reviews', label: 'Reviews' },
  { href: '/admin/requests', label: 'Change Requests' },
  { href: '/admin/documents', label: 'Documents' },
  { href: '/admin/services', label: 'Services' },
  { href: '/admin/content', label: 'Content' },
  { href: '/admin/seo', label: 'SEO' },
  { href: '/admin/analytics', label: 'Analytics' },
  { href: '/admin/health', label: 'Health' },
  { href: '/admin/settings', label: 'Settings' },
];

const current = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Admin</title>
  </head>
  <body class="min-h-screen bg-ink-50">
    <div class="flex min-h-screen">
      <aside class="w-64 bg-ink-900 text-ink-50 flex flex-col">
        <div class="px-6 py-5 border-b border-ink-700">
          <div class="text-lg font-semibold">Admin</div>
          {user?.email && <div class="text-xs text-ink-200 mt-1">{user.email}</div>}
        </div>
        <nav class="flex-1 px-3 py-4 space-y-1">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                'block px-3 py-2 rounded-md text-sm',
                current === item.href ? 'bg-brand-600 text-white' : 'hover:bg-ink-700',
              ]}
            >
              {item.label}
            </a>
          ))}
        </nav>
        <form method="POST" action="/admin/logout" class="p-3 border-t border-ink-700">
          <button class="w-full text-left px-3 py-2 text-sm rounded-md hover:bg-ink-700">
            Sign out
          </button>
        </form>
      </aside>
      <main class="flex-1 p-8">
        <header class="mb-6">
          <h1 class="text-2xl font-semibold text-ink-900">{title}</h1>
        </header>
        <slot />
      </main>
    </div>
  </body>
</html>
