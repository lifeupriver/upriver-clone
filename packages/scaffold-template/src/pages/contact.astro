---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/astro/ContactForm.astro';

// Default contact page — Hero/CTA components and the footer link here.
// The `upriver clone` pass replaces this with the source site's contact
// page when one exists.
---

<Layout title="Contact" description="Get in touch — send us a message and we'll respond within a business day.">
  <section class="mx-auto max-w-6xl px-6 py-16">
    <h1 class="text-3xl md:text-4xl font-display font-semibold text-ink-900 text-center">
      Contact us
    </h1>
    <p class="mt-4 text-lg text-ink-700 max-w-2xl mx-auto text-center">
      Send us a message and we'll get back to you within a business day.
    </p>
    <div class="mt-10">
      <ContactForm />
    </div>
  </section>
</Layout>
