---
import Layout from '../layouts/Layout.astro';
import { SITE_NAME } from '../site.config';

// PLACEHOLDER PAGE — ships with operator-marked stub copy so the footer's
// /privacy link never 404s. Launch QA must flag this page until the
// client's real policy replaces the marked block below.
---

<Layout title="Privacy Policy" description="Privacy policy">
  <section class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-3xl font-display font-semibold text-ink-900">Privacy Policy</h1>

    <div class="mt-6 rounded-card border-2 border-dashed border-red-400 bg-red-50 p-5 text-red-700">
      <p class="font-semibold">[Operator: replace with client-provided privacy policy]</p>
      <p class="mt-2 text-sm">
        This page is placeholder copy shipped with the scaffold template. It must be replaced
        with the client's actual privacy policy before launch — see the "Placeholder content"
        items in launch-checklist.md.
      </p>
    </div>

    <div class="mt-8 space-y-4 text-ink-700">
      <p>
        {SITE_NAME} respects your privacy. A real policy belongs here, covering at minimum:
      </p>
      <ul class="list-disc pl-6 space-y-2">
        <li>What personal information is collected (contact form name/email/message, newsletter email, analytics).</li>
        <li>How that information is used and how long it is retained.</li>
        <li>Which third parties process it (hosting, analytics, email tools).</li>
        <li>How visitors can request access to or deletion of their data.</li>
        <li>A contact method for privacy questions.</li>
      </ul>
    </div>
  </section>
</Layout>
