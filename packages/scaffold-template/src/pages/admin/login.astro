---
export const prerender = false;

import '../../styles/global.css';
import { createSupabaseServerClient, isSupabaseConfigured } from '../../lib/supabase-server';

// Email + password sign-in against the client's Supabase project. There is
// deliberately NO signup page — create the first admin user in the Supabase
// dashboard (Authentication → Users → Add user) or via the operator's
// provisioning. See README.md ("Admin access").
let error: string | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const email = String(form.get('email') ?? '').trim();
  const password = String(form.get('password') ?? '');

  if (!email || !password) {
    error = 'Email and password are required.';
  } else if (!isSupabaseConfigured()) {
    error = 'Supabase is not configured — set PUBLIC_SUPABASE_URL and PUBLIC_SUPABASE_ANON_KEY.';
  } else {
    try {
      // The @supabase/ssr server client writes the sb-* session cookies
      // through Astro.cookies on successful sign-in.
      const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
      const { error: signInError } = await supabase.auth.signInWithPassword({ email, password });
      if (!signInError) {
        return Astro.redirect('/admin');
      }
      error = signInError.message || 'Invalid credentials.';
    } catch (err) {
      error = err instanceof Error ? err.message : 'Sign-in failed.';
    }
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Sign in</title>
  </head>
  <body class="min-h-screen bg-ink-50 flex items-center justify-center">
    <form method="POST" class="w-full max-w-sm bg-white rounded-card border border-ink-200 p-6 shadow-sm space-y-4">
      <h1 class="text-xl font-semibold text-ink-900">Admin sign in</h1>

      {error && (
        <p class="text-sm text-red-600" role="alert">{error}</p>
      )}

      <div>
        <label for="email" class="block text-sm font-medium text-ink-900">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
          class="mt-1 block w-full rounded-button border border-ink-200 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500"
        />
      </div>

      <div>
        <label for="password" class="block text-sm font-medium text-ink-900">Password</label>
        <input
          id="password"
          name="password"
          type="password"
          required
          autocomplete="current-password"
          class="mt-1 block w-full rounded-button border border-ink-200 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500"
        />
      </div>

      <button
        type="submit"
        class="w-full rounded-button bg-brand-600 text-white px-4 py-2 font-medium hover:bg-brand-700"
      >
        Sign in
      </button>
    </form>
  </body>
</html>
