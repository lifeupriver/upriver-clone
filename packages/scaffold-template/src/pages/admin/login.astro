---
export const prerender = false;

import '../../styles/global.css';

let error: string | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const email = String(form.get('email') ?? '').trim();
  const password = String(form.get('password') ?? '');

  if (!email || !password) {
    error = 'Email and password are required.';
  } else {
    try {
      const { auth } = await import('../../lib/auth');
      const result = await auth.api.signInEmail({
        body: { email, password },
        headers: Astro.request.headers,
      });

      const token =
        (result as { token?: string } | undefined)?.token ??
        (result as { session?: { token?: string } } | undefined)?.session?.token;

      if (token) {
        Astro.cookies.set('upriver_session', token, {
          httpOnly: true,
          secure: true,
          sameSite: 'lax',
          path: '/',
          maxAge: 60 * 60 * 24 * 7,
        });
        return Astro.redirect('/admin/dashboard');
      }

      error = 'Invalid credentials.';
    } catch (err) {
      error = err instanceof Error ? err.message : 'Sign-in failed.';
    }
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Sign in</title>
  </head>
  <body class="min-h-screen bg-ink-50 flex items-center justify-center">
    <form method="POST" class="w-full max-w-sm bg-white rounded-card border border-ink-200 p-6 shadow-sm space-y-4">
      <h1 class="text-xl font-semibold text-ink-900">Admin sign in</h1>

      {error && (
        <p class="text-sm text-red-600" role="alert">{error}</p>
      )}

      <div>
        <label for="email" class="block text-sm font-medium text-ink-900">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
          class="mt-1 block w-full rounded-button border border-ink-200 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500"
        />
      </div>

      <div>
        <label for="password" class="block text-sm font-medium text-ink-900">Password</label>
        <input
          id="password"
          name="password"
          type="password"
          required
          autocomplete="current-password"
          class="mt-1 block w-full rounded-button border border-ink-200 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500"
        />
      </div>

      <button
        type="submit"
        class="w-full rounded-button bg-brand-600 text-white px-4 py-2 font-medium hover:bg-brand-700"
      >
        Sign in
      </button>
    </form>
  </body>
</html>
