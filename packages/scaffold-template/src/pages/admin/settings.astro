---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';

const rows = [
  { key: 'CLIENT_SLUG', description: 'Short identifier used across the toolchain.' },
  { key: 'PRODUCTION_URL', description: 'Public production URL for QA runs.' },
  { key: 'SUPABASE_URL', description: 'Supabase project URL.' },
  { key: 'GITHUB_OWNER / GITHUB_REPO', description: 'Target repo for change requests.' },
];
---

<AdminLayout title="Settings">
  <p class="text-sm text-ink-500 mb-4">
    Environment is set at the deploy target (Vercel). This page summarizes
    which keys are expected. Secrets are never rendered.
  </p>

  <div class="rounded-card border border-ink-200 bg-white overflow-hidden">
    <table class="min-w-full divide-y divide-ink-200">
      <thead class="bg-ink-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-ink-500 uppercase">Key</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-ink-500 uppercase">Purpose</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-ink-100">
        {rows.map((r) => (
          <tr>
            <td class="px-4 py-3 font-mono text-sm text-ink-900">{r.key}</td>
            <td class="px-4 py-3 text-sm text-ink-700">{r.description}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</AdminLayout>
