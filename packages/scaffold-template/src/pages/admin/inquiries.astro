---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';

interface Inquiry {
  id: string;
  created_at: string;
  name: string;
  email: string;
  message: string;
  status: string;
}

let inquiries: Inquiry[] = [];
let loadError: string | null = null;

try {
  const { data, error } = await supabaseAdmin
    .from('inquiries')
    .select('*')
    .order('created_at', { ascending: false })
    .limit(50);
  if (error) throw error;
  inquiries = (data ?? []) as Inquiry[];
} catch (err) {
  loadError = err instanceof Error ? err.message : String(err);
}
---

<AdminLayout title="Inquiries">
  {loadError && (
    <p class="mb-4 rounded-card border border-red-200 bg-red-50 p-3 text-sm text-red-700">
      Could not load inquiries: {loadError}
    </p>
  )}

  <div class="rounded-card border border-ink-200 bg-white overflow-hidden">
    <table class="min-w-full divide-y divide-ink-200">
      <thead class="bg-ink-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-ink-500 uppercase">Received</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-ink-500 uppercase">Name</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-ink-500 uppercase">Email</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-ink-500 uppercase">Message</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-ink-500 uppercase">Status</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-ink-100">
        {inquiries.length === 0 ? (
          <tr><td colspan="5" class="px-4 py-8 text-center text-sm text-ink-500">No inquiries yet.</td></tr>
        ) : (
          inquiries.map((i) => (
            <tr>
              <td class="px-4 py-3 text-sm text-ink-700">{new Date(i.created_at).toLocaleString()}</td>
              <td class="px-4 py-3 text-sm text-ink-900">{i.name}</td>
              <td class="px-4 py-3 text-sm text-ink-700">{i.email}</td>
              <td class="px-4 py-3 text-sm text-ink-700 max-w-md truncate">{i.message}</td>
              <td class="px-4 py-3 text-sm text-ink-700">{i.status}</td>
            </tr>
          ))
        )}
      </tbody>
    </table>
  </div>
</AdminLayout>
