---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';

interface Doc {
  id: string;
  created_at: string;
  title: string;
  category: string;
  file_url: string;
}

let documents: Doc[] = [];
let loadError: string | null = null;

try {
  const { data, error } = await supabaseAdmin
    .from('documents')
    .select('*')
    .order('created_at', { ascending: false });
  if (error) throw error;
  documents = (data ?? []) as Doc[];
} catch (err) {
  loadError = err instanceof Error ? err.message : String(err);
}
---

<AdminLayout title="Documents">
  {loadError && (
    <p class="mb-4 rounded-card border border-red-200 bg-red-50 p-3 text-sm text-red-700">
      Could not load documents: {loadError}
    </p>
  )}

  <div class="rounded-card border border-ink-200 bg-white p-5">
    {documents.length === 0 ? (
      <p class="text-sm text-ink-500">No documents uploaded yet.</p>
    ) : (
      <ul class="divide-y divide-ink-100">
        {documents.map((d) => (
          <li class="py-3 flex items-center justify-between">
            <div>
              <a href={d.file_url} class="font-medium text-ink-900 hover:text-brand-600">{d.title}</a>
              <div class="text-xs text-ink-500">{d.category} · {new Date(d.created_at).toLocaleDateString()}</div>
            </div>
          </li>
        ))}
      </ul>
    )}
  </div>
</AdminLayout>
