---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import ChangeRequestForm from '../../components/react/ChangeRequestForm.tsx';
import { supabaseAdmin } from '../../lib/supabase';

interface ChangeRequest {
  id: string;
  created_at: string;
  title: string;
  body: string;
  github_issue_url: string | null;
  status: string;
}

let requests: ChangeRequest[] = [];
let loadError: string | null = null;

try {
  const { data, error } = await supabaseAdmin
    .from('change_requests')
    .select('*')
    .order('created_at', { ascending: false })
    .limit(50);
  if (error) throw error;
  requests = (data ?? []) as ChangeRequest[];
} catch (err) {
  loadError = err instanceof Error ? err.message : String(err);
}
---

<AdminLayout title="Change Requests">
  <div class="grid gap-6 lg:grid-cols-[1fr_1.2fr]">
    <section>
      <h2 class="text-lg font-semibold text-ink-900">New request</h2>
      <p class="mt-1 text-sm text-ink-500">
        Submits a GitHub issue labeled <code>client-request</code>.
        Claude Code Action will read it and open a draft PR.
      </p>
      <div class="mt-3">
        <ChangeRequestForm client:load />
      </div>
    </section>

    <section>
      <h2 class="text-lg font-semibold text-ink-900">Recent requests</h2>
      {loadError && (
        <p class="mt-2 rounded-card border border-red-200 bg-red-50 p-3 text-sm text-red-700">
          Could not load change requests: {loadError}
        </p>
      )}
      <ul class="mt-3 space-y-3">
        {requests.length === 0 ? (
          <li class="text-sm text-ink-500">No change requests yet.</li>
        ) : (
          requests.map((r) => (
            <li class="rounded-card border border-ink-200 bg-white p-4">
              <div class="flex items-center justify-between">
                <div class="font-medium text-ink-900">{r.title}</div>
                <span class="text-xs text-ink-500">{r.status}</span>
              </div>
              <p class="mt-1 text-sm text-ink-700 line-clamp-3">{r.body}</p>
              {r.github_issue_url && (
                <a href={r.github_issue_url} class="mt-2 inline-block text-sm text-brand-600 hover:underline">
                  View on GitHub →
                </a>
              )}
            </li>
          ))
        )}
      </ul>
    </section>
  </div>
</AdminLayout>
