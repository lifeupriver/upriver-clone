---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import AdminIsland from '../../components/react/AdminIsland.tsx';

const stats = [
  { label: 'Open inquiries', value: '—' },
  { label: 'Pending reviews', value: '—' },
  { label: 'Open change requests', value: '—' },
  { label: 'Uptime (30d)', value: '—' },
];
---

<AdminLayout title="Dashboard">
  <div class="grid gap-4 md:grid-cols-4">
    {stats.map((s) => (
      <div class="rounded-card border border-ink-200 bg-white p-5">
        <div class="text-sm text-ink-500">{s.label}</div>
        <div class="mt-2 text-2xl font-semibold text-ink-900">{s.value}</div>
      </div>
    ))}
  </div>

  <div class="mt-6">
    <AdminIsland client:load title="Recent activity" />
  </div>
</AdminLayout>
