---
// Self-contained image carousel with prev/next + indicator dots + optional
// autoplay. No React island — vanilla JS scoped via [data-carousel-id].
//
// Usage:
//   ---
//   import Carousel from '@/components/astro/Carousel.astro';
//   const slides = [
//     { src: 'https://.../1.jpg', alt: 'Wedding reception' },
//     { src: 'https://.../2.jpg', alt: 'Greenhouse interior' },
//   ];
//   ---
//   <Carousel slides={slides} autoplayMs={6000} className="h-screen min-h-[480px]" />

interface Slide {
  src: string;
  alt: string;
}

interface Props {
  slides: Slide[];
  autoplayMs?: number;
  className?: string; // Tailwind classes applied to the outer wrapper
  showArrows?: boolean;
  showIndicators?: boolean;
  fit?: 'cover' | 'contain';
  loading?: 'eager' | 'lazy';
}

const {
  slides,
  autoplayMs = 0,
  className = '',
  showArrows = true,
  showIndicators = true,
  fit = 'cover',
  loading = 'eager',
} = Astro.props as Props;

const id = `c-${Math.random().toString(36).slice(2, 10)}`;
---

<div
  class:list={['relative overflow-hidden group', className]}
  data-carousel-id={id}
  data-autoplay-ms={autoplayMs}
  role="region"
  aria-roledescription="carousel"
  aria-label="Image carousel"
>
  {/* Slides */}
  <div class="relative w-full h-full" data-carousel-track>
    {slides.map((s, i) => (
      <div
        class="absolute inset-0 transition-opacity duration-500"
        style={`opacity: ${i === 0 ? 1 : 0};`}
        data-carousel-slide
        aria-hidden={i === 0 ? 'false' : 'true'}
        role="group"
        aria-roledescription="slide"
        aria-label={`${i + 1} of ${slides.length}`}
      >
        <img
          src={s.src}
          alt={s.alt}
          loading={i === 0 ? loading : 'lazy'}
          fetchpriority={i === 0 ? 'high' : 'auto'}
          class:list={['w-full h-full', fit === 'cover' ? 'object-cover' : 'object-contain']}
        />
      </div>
    ))}
  </div>

  {/* Prev / next buttons */}
  {showArrows && slides.length > 1 && (
    <>
      <button
        type="button"
        class="absolute left-4 top-1/2 -translate-y-1/2 z-10 w-10 h-10 flex items-center justify-center bg-white/30 hover:bg-white/60 backdrop-blur-sm transition-colors opacity-0 group-hover:opacity-100 focus:opacity-100"
        data-carousel-prev
        aria-label="Previous slide"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button
        type="button"
        class="absolute right-4 top-1/2 -translate-y-1/2 z-10 w-10 h-10 flex items-center justify-center bg-white/30 hover:bg-white/60 backdrop-blur-sm transition-colors opacity-0 group-hover:opacity-100 focus:opacity-100"
        data-carousel-next
        aria-label="Next slide"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </>
  )}

  {/* Indicator dots */}
  {showIndicators && slides.length > 1 && (
    <div
      class="absolute bottom-4 left-1/2 -translate-x-1/2 z-10 flex gap-2"
      data-carousel-indicators
      role="tablist"
    >
      {slides.map((_, i) => (
        <button
          type="button"
          class="w-2 h-2 rounded-full bg-white/60 hover:bg-white transition-colors data-[active=true]:bg-white data-[active=true]:w-6"
          data-carousel-indicator={i}
          data-active={i === 0 ? 'true' : 'false'}
          aria-label={`Go to slide ${i + 1}`}
        />
      ))}
    </div>
  )}
</div>

<script define:vars={{ id }}>
  const root = document.querySelector(`[data-carousel-id="${id}"]`);
  if (root) {
    const slides = root.querySelectorAll('[data-carousel-slide]');
    const indicators = root.querySelectorAll('[data-carousel-indicator]');
    const prevBtn = root.querySelector('[data-carousel-prev]');
    const nextBtn = root.querySelector('[data-carousel-next]');
    const autoplayMs = Number(root.getAttribute('data-autoplay-ms') || '0');
    let current = 0;
    let timer = null;

    const go = (i) => {
      const next = ((i % slides.length) + slides.length) % slides.length;
      slides.forEach((s, idx) => {
        s.style.opacity = idx === next ? '1' : '0';
        s.setAttribute('aria-hidden', idx === next ? 'false' : 'true');
      });
      indicators.forEach((d, idx) => {
        d.setAttribute('data-active', idx === next ? 'true' : 'false');
      });
      current = next;
    };

    prevBtn?.addEventListener('click', () => { go(current - 1); restart(); });
    nextBtn?.addEventListener('click', () => { go(current + 1); restart(); });
    indicators.forEach((d, i) => d.addEventListener('click', () => { go(i); restart(); }));

    // Keyboard nav (when carousel has focus)
    root.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') { go(current - 1); restart(); }
      else if (e.key === 'ArrowRight') { go(current + 1); restart(); }
    });
    if (!root.hasAttribute('tabindex')) root.setAttribute('tabindex', '0');

    const start = () => {
      if (autoplayMs > 0) timer = setInterval(() => go(current + 1), autoplayMs);
    };
    const stop = () => { if (timer) { clearInterval(timer); timer = null; } };
    const restart = () => { stop(); start(); };

    // Pause on hover
    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);
    // Pause when off-screen
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(([entry]) => {
        if (entry.isIntersecting) start(); else stop();
      });
      io.observe(root);
    } else {
      start();
    }
  }
</script>
