---
// Primary site navigation. The `upriver scaffold` command replaces this
// component's `navItems` array from the discovered site map before the
// template is written into the client repo.
//
// Sizing is driven by CSS custom properties emitted in `global.css` from
// `upriver capture-typography` (see clients/<slug>/typography-capture.json).
// `--logo-height`, `--font-size-nav`, and `--font-weight-nav` will fall back
// to sensible defaults if the capture step hasn't run.
import { SITE_NAME } from '../../site.config';

const navItems: { href: string; label: string }[] = [
  { href: '/', label: 'Home' },
];
---

<header class="bg-white">
  <div class="mx-auto max-w-7xl px-6 py-3 flex items-center justify-between gap-6">
    <a href="/" class="flex items-center" aria-label="Home">
      {/*
        Logo size honors --logo-height. The scaffold's image-copy step writes
        the brand logo to /public/images/<filename>; replace the src below in
        the Astro page that imports this component, or keep this stub.
      */}
      <span
        class="font-semibold text-ink-900"
        style="font-size: var(--font-size-nav, 18px);"
      >
        {SITE_NAME}
      </span>
    </a>
    <nav class="hidden lg:flex items-center" aria-label="Primary" style="gap: 1.75rem;">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-ink-900 hover:text-brand-600 transition-colors"
          style="font-size: var(--font-size-nav, 14px); font-weight: var(--font-weight-nav, 600);"
        >
          {item.label}
        </a>
      ))}
    </nav>
    <button
      class="lg:hidden text-ink-900"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      type="button"
      data-nav-toggle
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </div>
  <nav
    id="mobile-menu"
    class="lg:hidden hidden border-t border-ink-200 bg-white px-6 py-4"
    aria-label="Primary"
  >
    <ul class="flex flex-col gap-3">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="block text-ink-900 hover:text-brand-600 transition-colors"
            style="font-size: var(--font-size-nav, 16px); font-weight: var(--font-weight-nav, 600);"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const menu = document.getElementById('mobile-menu');

  function setOpen(open: boolean) {
    if (!toggle || !menu) return;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    menu.classList.toggle('hidden', !open);
  }

  toggle?.addEventListener('click', () => {
    setOpen(toggle.getAttribute('aria-expanded') !== 'true');
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') {
      setOpen(false);
      toggle.focus();
    }
  });
</script>
