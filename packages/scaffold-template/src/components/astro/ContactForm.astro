---
// Public inquiry form. Submits client-side to Supabase via the anon key,
// invoking the `submit_inquiry` RPC (defined in supabase/migrations/001_schema.sql).
---

<form id="contact-form" class="mx-auto max-w-xl space-y-4">
  <div>
    <label class="block text-sm font-medium text-ink-900" for="name">Name</label>
    <input
      id="name"
      name="name"
      type="text"
      required
      class="mt-1 block w-full rounded-button border border-ink-200 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500"
    />
  </div>
  <div>
    <label class="block text-sm font-medium text-ink-900" for="email">Email</label>
    <input
      id="email"
      name="email"
      type="email"
      required
      class="mt-1 block w-full rounded-button border border-ink-200 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500"
    />
  </div>
  <div>
    <label class="block text-sm font-medium text-ink-900" for="message">Message</label>
    <textarea
      id="message"
      name="message"
      rows="5"
      required
      class="mt-1 block w-full rounded-button border border-ink-200 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500"
    ></textarea>
  </div>
  <button
    type="submit"
    class="bg-brand-600 text-white px-6 py-3 rounded-button font-medium hover:bg-brand-700"
  >
    Send message
  </button>
  <p id="contact-status" class="text-sm" aria-live="polite"></p>
</form>

<script>
  import { supabase } from '../../lib/supabase';

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('contact-status');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!status) return;
    status.textContent = 'Sending…';
    status.className = 'text-sm text-ink-500';

    const data = new FormData(form);
    const payload = {
      p_name: String(data.get('name') ?? ''),
      p_email: String(data.get('email') ?? ''),
      p_message: String(data.get('message') ?? ''),
    };

    const { error } = await supabase.rpc('submit_inquiry', payload);
    if (error) {
      status.textContent = `Sorry — something went wrong: ${error.message}`;
      status.className = 'text-sm text-red-600';
      return;
    }

    status.textContent = 'Thanks — we will be in touch shortly.';
    status.className = 'text-sm text-green-700';
    form.reset();
  });
</script>
