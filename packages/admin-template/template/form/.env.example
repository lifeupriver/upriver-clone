# Configure these on the Vercel deployment, not in local files.

# GitHub repo to file issues against. Format: owner/repo.
GITHUB_REPO_TARGET=

# Fine-grained PAT scoped to the repo above with "Issues: read+write" permission.
# The form runs in a Vercel serverless function and uses this token to create issues.
GITHUB_PAT=

# Optional bcrypt hash of a 6-digit PIN. When set, the form requires the PIN on submit.
# Generate via: node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 10))" 123456
FORM_PIN_HASH=

# Public env (visible in the browser).
NEXT_PUBLIC_CLIENT_NAME=
NEXT_PUBLIC_PIN_REQUIRED=false
