# Firecrawl — required for all commands
FIRECRAWL_API_KEY=fc-...

# Google Search Console service account — required for GSC data in discover and seo audit
GOOGLE_SERVICE_ACCOUNT_KEY=/path/to/upriver-service-account.json

# Anthropic — required for synthesize, interview-prep, deep audit passes
ANTHROPIC_API_KEY=sk-ant-...
# Optional override; default is claude-sonnet-4-6
# UPRIVER_DEEP_MODEL=claude-sonnet-4-6

# Client-artifact data source. Default is `supabase` (the canonical store).
# Set to `local` to read/write `clients/<slug>/` on the local filesystem
# (offline operator work, fixtures, the Little Friends acceptance run).
# UPRIVER_DATA_SOURCE=local

# upriver-platform Supabase project (qavbpfmhgvkhrnbqalrp)
# Required unless UPRIVER_DATA_SOURCE=local — every command resolves the data
# source through these vars and fails with a clear message if they are unset.
UPRIVER_SUPABASE_URL=https://qavbpfmhgvkhrnbqalrp.supabase.co
UPRIVER_SUPABASE_PUBLISHABLE_KEY=sb_publishable_hy3i0LN--QsvbLXm03Amhw_8GLFGIOn
# Paste from Supabase dashboard → Settings → API → service_role key (NOT exposed via MCP):
UPRIVER_SUPABASE_SERVICE_KEY=eyJ...
# Optional — defaults to `upriver`
# UPRIVER_SUPABASE_BUCKET=upriver

# Resend — for `upriver report send` real delivery (falls back to manual-print when unset)
# RESEND_API_KEY=re_...
# Optional sender override; default is reports@upriverhudsonvalley.com (must be verified in Resend)
# UPRIVER_REPORT_FROM=reports@upriverhudsonvalley.com
# Optional report-host override; default is https://reports.upriverhudsonvalley.com
# UPRIVER_REPORT_HOST=https://reports.upriverhudsonvalley.com

# Dashboard auth — set when deploying anywhere reachable on the public internet
# Generate with: openssl rand -hex 24
# UPRIVER_RUN_TOKEN=

# Optional — committer identity for `upriver clone` / `upriver fixes apply` initial commits.
# Falls back to the bot identity if unset.
# UPRIVER_GIT_EMAIL=you@example.com
# UPRIVER_GIT_NAME=Your Name
