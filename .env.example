# Firecrawl — required for all commands
FIRECRAWL_API_KEY=fc-...

# Google Search Console service account — required for GSC data in discover and seo audit
GOOGLE_SERVICE_ACCOUNT_KEY=/path/to/upriver-service-account.json

# Upriver internal Supabase — required for usage event logging
UPRIVER_SUPABASE_URL=https://[project-ref].supabase.co
UPRIVER_SUPABASE_SERVICE_KEY=eyJ...

# Optional — committer identity for `upriver clone` / `upriver fixes apply` initial commits.
# Falls back to the bot identity if unset.
# UPRIVER_GIT_EMAIL=you@example.com
# UPRIVER_GIT_NAME=Your Name
